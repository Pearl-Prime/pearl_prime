# ═══════════════════════════════════════════════════════════════
# PHOENIX OMEGA — ENVIRONMENT VARIABLES (template)
# ═══════════════════════════════════════════════════════════════
# Canonical registry: scripts/ci/integration_env_registry.py
# Human docs:         docs/INTEGRATION_CREDENTIALS_REGISTRY.md
# Local source:       macOS Keychain (per CLAUDE.md)
# Load command:       eval "$(python3 scripts/ci/load_integration_env_from_keychain.py)"
# Validate:           python3 scripts/ci/check_integration_env.py
#
# This file is auto-generated by Pearl_Int from the registry tuples.
# Empty values are intentional — Phoenix Omega reads from Keychain, not .env.
# .env IS gitignored. This .env.example template IS committed.
# ═══════════════════════════════════════════════════════════════


# ── Pearl Star / Gemma ────────────────────────────────
# [REQUIRED] Gemma Ollama endpoint (English Tier 2). Default: http://192.168.1.101:11434/v1
GEMMA_BASE_URL=
# [optional] Gemma model override (default: gemma2:9b)
GEMMA_MODEL=

# ── Qwen / DashScope ──────────────────────────────────
# [REQUIRED] Qwen Ollama endpoint (CJK6 Tier 2). Default: http://192.168.1.101:11434/v1
QWEN_BASE_URL=
# [optional] Qwen model override (default: qwen2.5:7b)
QWEN_MODEL=
# [optional] DashScope API key (not needed for local Ollama)
QWEN_API_KEY=
# [optional] Alt env var for DashScope key
DASHSCOPE_API_KEY=
# [optional] Alt env var for DashScope URL
DASHSCOPE_BASE_URL=
# [optional] Alt env var for DashScope model
DASHSCOPE_MODEL=

# ── Anthropic ─────────────────────────────────────────
# [optional] NOT required for production — Tier 1 = Claude Code subscription
ANTHROPIC_API_KEY=
# [optional] Claude model selection (local dev reference only)
CLAUDE_MODEL=

# ── OpenAI ────────────────────────────────────────────
# [optional] OpenAI API key (TTS + fallback LLM)
OPENAI_API_KEY=

# ── Ollama ────────────────────────────────────────────
# [optional] Local Ollama endpoint
OLLAMA_HOST=
# [optional] Local Ollama model
OLLAMA_MODEL=

# ── DeepSeek ──────────────────────────────────────────
# [optional] zh-CN/zh-TW translation — deepseek-chat (V3). Get: platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# [optional] DeepSeek model override (default: deepseek-chat)
DEEPSEEK_MODEL=

# ── Google AI Studio ──────────────────────────────────
# [optional] ja-JP translation — Gemini 2.0 Flash, 1M tokens/day free. Get: aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
# [optional] Gemini model override (default: gemini-2.0-flash)
GEMINI_MODEL=

# ── Groq ──────────────────────────────────────────────
# [optional] Free EN default: llama-3.3-70b-versatile. Get: console.groq.com/keys
GROQ_API_KEY=

# ── xAI / Grok ────────────────────────────────────────
# [optional] Free EN fallback 1: grok-3-mini. $25/mo free credits. Get: console.x.ai
XAI_API_KEY=

# ── Together AI ───────────────────────────────────────
# [optional] Free EN fallback 2: Llama-3.3-70B-Instruct-Turbo-Free. 1M tokens/mo. Get: api.together.ai
TOGETHER_API_KEY=

# ── ElevenLabs ────────────────────────────────────────
# [optional] TTS (guided audio, journal prompts)
ELEVENLABS_API_KEY=

# ── Cloudflare ────────────────────────────────────────
# [optional] Workers AI + Pages
CLOUDFLARE_ACCOUNT_ID=
# [optional] Cloudflare API token. cfut_ prefix = Workers Builds (IP-locked to Cloudflare CI; CANNOT do Pages from a developer laptop)
CLOUDFLARE_API_TOKEN=
# [optional] Pages-scoped Custom token for local branch-preview deploys (must NOT have cfut_ prefix; create via dash.cloudflare.com/profile/api-tokens > Custom Token > Account:Cloudflare Pages:Edit, no IP filter)
CLOUDFLARE_API_TOKEN_PAGES=
# [optional] Workers AI inference token
CLOUDFLARE_AI_API_TOKEN=
# [optional] Workers AI OpenAI-compat base URL (accounts/<ID>/ai/v1)
CLOUDFLARE_AI_BASE_URL=
# [optional] Workers AI model name (e.g. @cf/google/gemma-3-12b-it)
CLOUDFLARE_AI_MODEL=

# ── Cloudflare R2 ─────────────────────────────────────
# [optional] R2 S3-compatible access key (bucket-scoped to phoenix-omega-artifacts). Get: dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
# [optional] R2 S3-compatible secret (shown once when access key created)
R2_SECRET_ACCESS_KEY=
# [optional] R2 account ID for S3 endpoint URL (same value as CLOUDFLARE_ACCOUNT_ID; scoped separately for r2_sync.py + setup_r2.sh consumers)
R2_ACCOUNT_ID=
# [optional] R2 bucket name (default: phoenix-omega-artifacts)
R2_BUCKET=
# [optional] S3 endpoint URL override. Set this for EU-jurisdiction or non-default-jurisdiction buckets where the host is NOT https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com. Cloudflare shows the correct URL on the R2 → Manage R2 API Tokens result page.
R2_ENDPOINT=

# ── GitHub ────────────────────────────────────────────
# [optional] GitHub API (auto in Actions)
GITHUB_TOKEN=
# [optional] owner/repo for API calls; auto in Actions
GITHUB_REPOSITORY=

# ── WordPress ─────────────────────────────────────────
# [optional] Pearl News publishing
WORDPRESS_SITE_URL=
# [optional] WordPress user
WORDPRESS_USERNAME=
# [optional] WordPress app password
WORDPRESS_APP_PASSWORD=

# ── GoHighLevel ───────────────────────────────────────
# [optional] Funnel CRM
GHL_API_KEY=
# [optional] GHL location
GHL_LOCATION_ID=
# [optional] GHL contacts / webhook URL
GHL_CONTACTS_URL=

# ── SMTP ──────────────────────────────────────────────
# [optional] Funnel email host
SMTP_HOST=
# [optional] Funnel email port
SMTP_PORT=
# [optional] Funnel email user
SMTP_USER=
# [optional] Funnel email password
SMTP_PASSWORD=

# ── Funnel ────────────────────────────────────────────
# [optional] Funnel sender email
FROM_EMAIL=
# [optional] Funnel sender name
FROM_NAME=
# [optional] Flask session key
SECRET_KEY=
# [optional] Funnel base URL
BASE_URL=

# ── Google Analytics ──────────────────────────────────
# [optional] Funnel analytics
GA4_MEASUREMENT_ID=

# ── YouTube (SP) ──────────────────────────────────────
# [optional] YouTube OAuth client ID — SoulPath
YT_CLIENT_ID_SP=
# [optional] YouTube OAuth client secret — SoulPath
YT_CLIENT_SECRET_SP=
# [optional] YouTube OAuth refresh token — SoulPath
YT_REFRESH_TOKEN_SP=

# ── YouTube (CC) ──────────────────────────────────────
# [optional] YouTube OAuth client ID — ConsciousCreator
YT_CLIENT_ID_CC=
# [optional] YouTube OAuth client secret — ConsciousCreator
YT_CLIENT_SECRET_CC=
# [optional] YouTube OAuth refresh token — ConsciousCreator
YT_REFRESH_TOKEN_CC=

# ── YouTube (ND) ──────────────────────────────────────
# [optional] YouTube OAuth client ID — NeuroDharma
YT_CLIENT_ID_ND=
# [optional] YouTube OAuth client secret — NeuroDharma
YT_CLIENT_SECRET_ND=
# [optional] YouTube OAuth refresh token — NeuroDharma
YT_REFRESH_TOKEN_ND=

# ── TikTok (SP) ───────────────────────────────────────
# [optional] TikTok client key — SoulPath
TIKTOK_CLIENT_KEY_SP=
# [optional] TikTok client secret — SoulPath
TIKTOK_CLIENT_SECRET_SP=
# [optional] TikTok access token — SoulPath
TIKTOK_ACCESS_TOKEN_SP=

# ── TikTok (CC) ───────────────────────────────────────
# [optional] TikTok client key — ConsciousCreator
TIKTOK_CLIENT_KEY_CC=
# [optional] TikTok client secret — ConsciousCreator
TIKTOK_CLIENT_SECRET_CC=
# [optional] TikTok access token — ConsciousCreator
TIKTOK_ACCESS_TOKEN_CC=

# ── TikTok (ND) ───────────────────────────────────────
# [optional] TikTok client key — NeuroDharma
TIKTOK_CLIENT_KEY_ND=
# [optional] TikTok client secret — NeuroDharma
TIKTOK_CLIENT_SECRET_ND=
# [optional] TikTok access token — NeuroDharma
TIKTOK_ACCESS_TOKEN_ND=

# ── Instagram (SP) ────────────────────────────────────
# [optional] Instagram access token — SoulPath
IG_ACCESS_TOKEN_SP=
# [optional] Instagram user ID — SoulPath
IG_USER_ID_SP=

# ── Instagram (CC) ────────────────────────────────────
# [optional] Instagram access token — ConsciousCreator
IG_ACCESS_TOKEN_CC=
# [optional] Instagram user ID — ConsciousCreator
IG_USER_ID_CC=

# ── Instagram (ND) ────────────────────────────────────
# [optional] Instagram access token — NeuroDharma
IG_ACCESS_TOKEN_ND=
# [optional] Instagram user ID — NeuroDharma
IG_USER_ID_ND=

# ── Bilibili ──────────────────────────────────────────
# [optional] Bilibili session cookie (disabled platform)
BILIBILI_SESSDATA=
# [optional] Bilibili CSRF token (disabled platform)
BILIBILI_CSRF=

# ── Douyin ────────────────────────────────────────────
# [optional] Douyin client key (disabled, needs ICP)
DOUYIN_CLIENT_KEY=
# [optional] Douyin client secret (disabled, needs ICP)
DOUYIN_CLIENT_SECRET=
# [optional] Douyin access token (disabled, needs ICP)
DOUYIN_ACCESS_TOKEN=

# ── SerpApi ───────────────────────────────────────────
# [optional] Trend checking (245 calls/month budget)
SERPAPI_KEY=

# ── Pearl Star ────────────────────────────────────────
# [REQUIRED] Pearl Star server LAN IP (ComfyUI, Ollama, CosyVoice2)
PEARL_STAR_IP=

# ── Pearl Star / ComfyUI ──────────────────────────────
# [REQUIRED] ComfyUI endpoint (e.g. http://${PEARL_STAR_IP}:8188)
COMFYUI_URL=

# ── Pearl Star / CosyVoice2 ───────────────────────────
# [optional] CosyVoice2 TTS endpoint (e.g. http://${PEARL_STAR_IP}:9880)
COSYVOICE_URL=

# ── Pearl Star / Hugging Face ─────────────────────────
# [optional] Hugging Face user access token for gated model downloads on Pearl Star (huggingface-cli / ComfyUI). macOS Keychain only — never commit the value.
HF_TOKEN=

# ── RunComfy ──────────────────────────────────────────
# [optional] RunComfy API key (FALLBACK image gen — cloud backup when ComfyUI unavailable)
RUNCOMFY_API_KEY=
# [optional] Alias accepted by some scripts/task briefs; same Bearer material as RUNCOMFY_API_KEY (Keychain parity per N3 2026-04-27)
RUNCOMFY_TOKEN=
# [optional] RunComfy deployment ID (default: 677edba8-ace0-4b2b-bad2-8e94b9959065)
RUNCOMFY_DEPLOYMENT_ID=
