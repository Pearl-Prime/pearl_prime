      \cf13 "text"\cf12 : \cf14 "What are some of your strengths? Maybe you're patient, or creative, or persistent. Maybe you're kind, or thoughtful, or brave. You have qualities that help you navigate life. Can you acknowledge these parts of yourself with appreciation? You don't have to be perfect to have real strengths."\cf12 \
    \cf11 \},\cf12 \
    \cf11 \{\cf12 \
      \cf13 "id"\cf12 : \cf14 "grat_015"\cf11 ,\cf12 \
      \cf13 "name"\cf12 : \cf14 "Sensory Pleasure"\cf11 ,\cf12 \
      \cf13 "category"\cf12 : \cf14 "micro_moments"\cf11 ,\cf12 \
      \cf13 "duration_seconds"\cf12 : \cf15 75\cf11 ,\cf12 \
      \cf13 "difficulty"\cf12 : \cf14 "beginner"\cf11 ,\cf12 \
