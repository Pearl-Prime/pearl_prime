#!/usr/bin/env python3\
\
"""\
\
phoenix_v4/quality/story_atom_lint.py\
\
\
\
Deterministic story-atom linting:\
\
- checks specificity, conflict, cost, insight pivot\
\
- scores PASS/WARN/FAIL\
\
- supports single file or directory recursion\
\
\
\
Usage:\
\
  PYTHONPATH=. python3 phoenix_v4/quality/story_atom_lint.py --path atoms/... --json-out artifacts/ops/story_lint.json\
\
"""\
\
\
\
from __future__ import annotations\
\
\
\
import argparse\
\
import json\
\
import os\
\
import re\
\
from dataclasses import dataclass, asdict\
\
from pathlib import Path\
\
from typing import Dict, List, Optional, Tuple\
\
\
\
# -----------------------------\
\
# Patterns (tweakable)\
\
# -----------------------------\
\
\
\
ACTION_VERBS = [\
\
    r"\\b(sat|stood|walked|drove|ran|stared|grabbed|held|shook|typed|called|texted|opened|closed|slammed)\\b",\
\
]\
\
SENSORY_WORDS = [\
\
    r"\\b(cold|warm|loud|silent|tight|heavy|burning|buzzing|aching|sweaty|shaky)\\b",\
\
]\
\
CONFLICT_MARKERS = [\
\
    r"\\b(but|however|although|yet)\\b",\
\
    r"\\b(couldn[\'92']t|cannot|can\'92t)\\b",\
\
    r"\\b(wanted to|should)\\b",\
\
]\
\
COST_MARKERS = [\
\
    r"\\b(lost|exhausted|ashamed|avoided|broke|collapsed|quit)\\b",\
\
    r"\\b(couldn[\'92']t sleep|stopped eating|panic|crying)\\b",\
\
]\
\
PIVOT_MARKERS = [\
\
    r"\\b(I|she|he|they)\\s+(realized|noticed|understood|saw|recognized)\\b",\
\
    r"\\b(the truth was|that\'92s when|thats when|it hit (me|her|him)|what (I|she|he) didn[\'92']t know)\\b",\
\
]\
\
\
\
SENTENCE_START_RE = re.compile(r"^[\\"'(\\[]*[A-Z]")\
\
\
\
# Proper noun heuristic: capitalized word not at sentence start, not "I"\
\
PROPER_NOUN_RE = re.compile(r"\\b(?!I\\b)[A-Z][a-z]\{2,\}\\b")\
\
\
\
WORD_RE = re.compile(r"\\b[\\w\'92']+\\b")\
\
\
\
# -----------------------------\
\
# Data\
\
# -----------------------------\
\
\
\
@dataclass(frozen=True)\
\
class StoryLintResult:\
\
    path: str\
\
    story_id: str\
\
    word_count: int\
\
    flags: List[str]\
\
    missing_signals: int\
\
    status: str  # PASS/WARN/FAIL\
\
    notes: List[str]\
\
\
\
# -----------------------------\
\
# Helpers\
\
# -----------------------------\
\
\
\
def normalize_text(text: str) -> str:\
\
    text = text.replace("\\r\\n", "\\n").replace("\\r", "\\n")\
\
    # collapse extra spaces but keep newlines\
\
    text = re.sub(r"[ \\t]+", " ", text)\
\
    return text.strip()\
\
\
\
def word_count(text: str) -> int:\
\
    return len(WORD_RE.findall(text))\
\
\
\
def count_hits(text: str, patterns: List[str]) -> int:\
\
    flags = re.IGNORECASE | re.MULTILINE\
\
    return sum(len(re.findall(p, text, flags)) for p in patterns)\
\
\
\
def has_any(text: str, patterns: List[str]) -> bool:\
\
    return count_hits(text, patterns) > 0\
\
\
\
def count_proper_nouns(text: str) -> int:\
\
    # naive: count capitalized words not at beginning of sentence\
\
    # We approximate by removing sentence-initial tokens.\
\
    tokens = PROPER_NOUN_RE.findall(text)\
\
    # This is already imperfect but deterministic.\
\
    return len(tokens)\
\
\
\
def derive_story_id(path: Path) -> str:\
\
    # You can customize this if your story files embed IDs.\
\
    return path.stem\
\
\
\
def lint_story(text: str, path: Path) -> StoryLintResult:\
\
    text = normalize_text(text)\
\
    wc = word_count(text)\
\
\
\
    flags: List[str] = []\
\
    notes: List[str] = []\
\
\
\
    # Length checks\
\
    if wc < 120:\
\
        flags.append("TOO_SHORT_LT_120")\
\
\
\
    # Specificity: proper noun OR action verb OR sensory word\
\
    proper_n = count_proper_nouns(text)\
\
    has_action = has_any(text, ACTION_VERBS)\
\
    has_sensory = has_any(text, SENSORY_WORDS)\
\
    if (proper_n == 0) and (not has_action) and (not has_sensory):\
\
        flags.append("NO_SPECIFIC_DETAIL")\
\
\
\
    # Conflict\
\
    if not has_any(text, CONFLICT_MARKERS):\
\
        flags.append("NO_INTERNAL_CONFLICT")\
\
\
\
    # Cost\
\
    if not has_any(text, COST_MARKERS):\
\
        flags.append("NO_COST_SIGNAL")\
\
\
\
    # Pivot\
\
    pivot = has_any(text, PIVOT_MARKERS)\
\
    if not pivot:\
\
        flags.append("NO_INSIGHT_PIVOT")\
\
        if wc < 180:\
\
            notes.append("Short story with no pivot tends to read generic.")\
\
\
\
    # Score\
\
    # Missing \'93signals\'94 excludes length (length is hard structural)\
\
    signal_flags = \{"NO_SPECIFIC_DETAIL", "NO_INTERNAL_CONFLICT", "NO_COST_SIGNAL", "NO_INSIGHT_PIVOT"\}\
\
    missing = sum(1 for f in flags if f in signal_flags)\
\
\
\
    status = "PASS"\
\
    if "TOO_SHORT_LT_120" in flags or missing >= 3:\
\
        status = "FAIL"\
\
    elif missing == 2:\
\
        status = "WARN"\
\
\
\
    return StoryLintResult(\
\
        path=str(path),\
\
        story_id=derive_story_id(path),\
\
        word_count=wc,\
\
        flags=flags,\
\
        missing_signals=missing,\
\
        status=status,\
\
        notes=notes,\
\
    )\
\
\
\
def iter_text_files(root: Path) -> List[Path]:\
\
    if root.is_file():\
\
        return [root]\
\
    files: List[Path] = []\
\
    for p in root.rglob("*"):\
\
        if p.is_file() and p.suffix.lower() in (".txt", ".md"):\
\
            files.append(p)\
\
    return sorted(files)\
\
\
\
# -----------------------------\
\
# CLI\
\
# -----------------------------\
\
\
\
def parse_args() -> argparse.Namespace:\
\
    ap = argparse.ArgumentParser()\
\
    ap.add_argument("--path", required=True, help="File or directory of story atoms")\
\
    ap.add_argument("--json-out", default=None, help="Write JSON report to this path")\
\
    ap.add_argument("--fail-on", choices=["PASS", "WARN", "FAIL"], default="FAIL",\
\
                    help="Exit nonzero if any result is at/above this severity")\
\
    return ap.parse_args()\
\
\
\
_SEVERITY = \{"PASS": 0, "WARN": 1, "FAIL": 2\}\
\
\
\
def main() -> int:\
\
    args = parse_args()\
\
    root = Path(args.path)\
\
\
\
    results: List[StoryLintResult] = []\
\
    for f in iter_text_files(root):\
\
        try:\
\
            text = f.read_text(encoding="utf-8", errors="replace")\
\
        except Exception as e:\
\
            results.append(StoryLintResult(\
\
                path=str(f),\
\
                story_id=derive_story_id(f),\
\
                word_count=0,\
\
                flags=["READ_ERROR"],\
\
                missing_signals=4,\
\
                status="FAIL",\
\
                notes=[str(e)],\
\
            ))\
\
            continue\
\
        results.append(lint_story(text, f))\
\
\
\
    # Summary\
\
    counts = \{"PASS": 0, "WARN": 0, "FAIL": 0\}\
\
    for r in results:\
\
        counts[r.status] += 1\
\
\
\
    payload = \{\
\
        "schema_version": "1.0",\
\
        "path": str(root),\
\
        "summary": \{"counts": counts, "total": len(results)\},\
\
        "results": [asdict(r) for r in results],\
\
    \}\
\
\
\
    if args.json_out:\
\
        outp = Path(args.json_out)\
\
        outp.parent.mkdir(parents=True, exist_ok=True)\
\
        outp.write_text(json.dumps(payload, indent=2, ensure_ascii=False), encoding="utf-8")\
\
\
\
    # Print top failures\
\
    top = [r for r in results if r.status != "PASS"][:20]\
\
    if top:\
\
        print("\\nTop issues:")\
\
        for r in top:\
\
            print(f"- \{r.status\} \{r.story_id\} (\{r.word_count\}w) \{Path(r.path).name\} :: \{', '.join(r.flags)\}")\
\
\
\
    # Exit rule\
\
    threshold = _SEVERITY[args.fail_on]\
\
    worst = max((_SEVERITY[r.status] for r in results), default=0)\
\
    return 1 if worst >= threshold and threshold > 0 else 0\
\
\
\
if __name__ == "__main__":\
\
    raise SystemExit(main())
