\uc0\u9500 \u9472 \u9472  Social Anxiety\
\uc0\u9474    \u9500 \u9472 \u9472  PERSONA LAYER (Model C)\
\uc0\u9474    \u9474    \u9500 \u9472 \u9472  Gen Z Professional edition\
\uc0\u9474    \u9474    \u9500 \u9472 \u9472  Healthcare RN edition\
\uc0\u9474    \u9474    \u9492 \u9472 \u9472  Gen Alpha Student edition\
\uc0\u9474    \u9492 \u9472 \u9472  DEPTH LAYER (Model B \'97 optional, only for Tier 1 topics)\
\uc0\u9474        \u9500 \u9472 \u9472  Book 1: Recognition + Foundations\
\uc0\u9474        \u9492 \u9472 \u9472  Book 2: Advanced Tools + Integration\
\uc0\u9474 \
