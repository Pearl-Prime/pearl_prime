Validation gates (post-generation, before file write)\
python\
def validate_integration_file(content):\
    errors = []\
    atoms = parse_atoms(content)  # split on ## INTEGRATION vNN\
\
    if len(atoms) != 7:\
        errors.append(f"FAIL: \{len(atoms)\} atoms, need 7")\
\
    modes = [a['mode'] for a in atoms]\
    if len(set(modes)) < 5:\
        errors.append(f"FAIL: only \{len(set(modes))\} unique modes")\
    if modes.count('STILL_HERE') != 1:\
        errors.append(f"FAIL: STILL_HERE count = \{modes.count('STILL_HERE')\}, need 1")\
\
    banned = ["you're okay","you've got this","you're safe",\
              "trust the process","you are enough","you've got this"]\
    for phrase in banned:\
        if phrase in content.lower():\
            errors.append(f"FAIL: banned phrase '\{phrase\}'")\
\
    if '?' in content:\
        errors.append("FAIL: question mark found")\
\
    for a in atoms:\
        carry = a['carry_line']\
        if len(carry.split()) > 8:\
            errors.append(f"FAIL: carry line too long (\{len(carry.split())\}w): \{carry\}")\
\
        wc = len(a['prose'].split())\
        limits = \{'light':(150,200),'standard':(120,160),\
                  'heavy':(80,130),'interrupt_landing':(80,120)\}\
        lo, hi = limits[a['weight']]\
        if not (lo <= wc <= hi):\
            errors.append(f"FAIL v\{a['num']\}: \{wc\}w, need \{lo\}-\{hi\} for \{a['weight']\}")\
\
    return errors\
