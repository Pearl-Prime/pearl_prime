\fs28 \cf15 \cb14 # config/compliance/therapeutic_guardrails.yaml\cf16 \
\pard\pardeftab720\partightenfactor0
\cf17 therapeutic_guardrails\cf18 :\cf16 \
  \cf17 polyvagal_theory\cf18 :\cf16 \
    \cf17 status\cf18 :\cf16  \cf21 "Academically contested. Critiques exist in peer-reviewed literature."\cf16 \
    \cf17 rule\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       If referencing polyvagal concepts (ventral vagal, dorsal vagal,\
      social engagement system), ALWAYS frame as "one model" or\
      "a framework some researchers use" \'97 never as established fact.\
\pard\pardeftab720\partightenfactor0
\cf21       Provide alternative evidence-based framing alongside.\cf16 \
    \cf17 safe_alternative\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Use "nervous system regulation" and "relaxation response" \'97\
\pard\pardeftab720\partightenfactor0
\cf21       these are well-supported without contested theoretical claims.\cf16 \
    \cf17 lint_trigger\cf18 :\cf16  \cf18 [\cf21 "polyvagal"\cf18 ,\cf16  \cf21 "ventral vagal"\cf18 ,\cf16  \cf21 "dorsal vagal"\cf18 ,\cf16  \cf21 "Stephen Porges"\cf18 ]\cf16 \
\
  \cf17 somatic_claims\cf18 :\cf16 \
    \cf17 rule\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Position somatic content as evidence-bounded relaxation training.\
      Relaxation therapy has meta-analytic support for generalized\
\pard\pardeftab720\partightenfactor0
\cf21       anxiety disorder. Stay within that evidence boundary.\cf16 \
    \cf17 safe_framing\cf18 :\cf16 \
      \cf18 -\cf16  \cf21 "Relaxation and breathing practices"\cf16 \
      \cf18 -\cf16  \cf21 "Body-based calming techniques"\cf16 \
      \cf18 -\cf16  \cf21 "Practices that support nervous system regulation"\cf16 \
    \cf17 unsafe_framing\cf18 :\cf16 \
      \cf18 -\cf16  "Releases trauma stored in the body" (overclaim)\
      \cf18 -\cf16  "Heals your vagus nerve" (mechanistic overclaim)\
      \cf18 -\cf16  "Rewires your nervous system" (overclaim without evidence)\
\
  \cf17 habit_formation\cf18 :\cf16 \
    \cf17 rule\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Research shows habit automaticity varies from 18 to 254 days\
\pard\pardeftab720\partightenfactor0
\cf21       (mean ~66 days). The "21 days" claim is a myth.\cf16 \
    \cf17 required_framing\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Use "8-10 week ramp" or "several weeks to months" for\
\pard\pardeftab720\partightenfactor0
\cf21       habit formation timelines. Never promise "21 days."\cf16 \
    \cf17 lint_trigger\cf18 :\cf16  \cf18 [\cf21 "21 days"\cf18 ,\cf16  \cf21 "21-day"\cf18 ,\cf16  \cf21 "three weeks to form a habit"\cf18 ]\cf16 \
\
  \cf17 implementation_intentions\cf18 :\cf16 \
    \cf17 rule\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       If/then planning (implementation intentions) has strong\
      meta-analytic support for goal attainment. Use as a standard\
\pard\pardeftab720\partightenfactor0
\cf21       EXERCISE atom format for habit/productivity topics.\cf16 \
    \cf17 format\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Every habit/productivity chapter should end with an\
      if/then plan template: "IF [trigger situation],\
\pard\pardeftab720\partightenfactor0
\cf21       THEN I will [specific action]."\cf16 \
    \cf17 atom_type\cf18 :\cf16  EXERCISE\
    \cf17 subtype\cf18 :\cf16  implementation_intention\
\
  \cf17 depression_content\cf18 :\cf16 \
    \cf17 rule\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Position as "feeling stuck" and "behavioral activation."\
      Never suggest audiobook replaces professional treatment\
\pard\pardeftab720\partightenfactor0
\cf21       for clinical depression. Include crisis resources.\cf16 \
    \cf17 required\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Any book with topic_id=depression must include crisis\
      resource information (988 Suicide & Crisis Lifeline)\
\pard\pardeftab720\partightenfactor0
\cf21       in the copyright page and audio outro.\cf16 \
\
  \cf17 suicide_self_harm\cf18 :\cf16 \
    \cf17 rule\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16       Content must never include methods, means, or instructions.\
      If content touches on suicidal ideation (even obliquely),\
\pard\pardeftab720\partightenfactor0
\cf21       include crisis resources immediately.\cf16 \
    \cf17 required_resources\cf18 :\cf16 \
      \cf18 -\cf16  \cf21 "988 Suicide & Crisis Lifeline: call or text 988"\cf16 \
      \cf18 -\cf16  \cf21 "Crisis Text Line: text HOME to 741741"\cf16 \cb1 \
