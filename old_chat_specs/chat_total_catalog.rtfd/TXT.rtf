\
    \cf18 -\cf16  \cf17 condition\cf18 :\cf16  topic_id IN \cf18 [\cf16 somatic_healing\cf18 ,\cf16  sleep_anxiety\cf18 ,\cf16  grief\cf18 ]\cf16 \
      \cf17 narration\cf18 :\cf16  human_preferred\
