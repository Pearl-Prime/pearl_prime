\cf2 \cb7 The First 30 Seconds Spec (Spotify Conversion Surface)\cb1 \
\cb7 Research shows that on Spotify, three "weak signals" predict whether a listener will initiate a full stream: follow, 30-second preview listen, and intent-to-pay. The 30-second sample is the single highest-leverage conversion surface across all platforms.\cb1 \
\cb7 Every book's opening must be engineered as a conversion surface, not just a chapter introduction.\cb1 \
\
\pard\pardeftab720\partightenfactor0

\fs24 \cf5 \cb14 yaml\cb1 \
\pard\pardeftab720\partightenfactor0

\fs28 \cf15 \cb14 # config/production/first_30_seconds_spec.yaml\cf21 \
\pard\pardeftab720\partightenfactor0
\cf17 first_30_seconds\cf18 :\cf21 \
  \cf17 required_elements\cf18 :\cf21 \
    \cf18 -\cf21  \cf17 element\cf18 :\cf21  problem_statement\
      \cf17 timing\cf18 :\cf21  "0:00-0:10"\
      \cf17 description\cf18 :\cf21  \cf18 >\cf21 \
        Name the listener's problem in their language.\
        Use consumer_language_map.yaml terms, not clinical terms.\
        Example: "You know that thing where your brain won't shut off\
        at 2am \'97 where you replay the conversation, rehearse the apology,\
        and plan for disasters that never come?"\
\
    \cf18 -\cf21  \cf17 element\cf18 :\cf21  immediate_tool_preview\
      \cf17 timing\cf18 :\cf21  "0:10-0:20"\
      \cf17 description\cf18 :\cf21  \cf18 >\cf21 \
        Preview the shift the book delivers. Concrete, not promissory.\
        Example: "This book gives you a way to interrupt the loop \'97\
        not by fighting it, but by understanding why it's running."\
\
    \cf18 -\cf21  \cf17 element\cf18 :\cf21  tone_trust_cue\
      \cf17 timing\cf18 :\cf21  "0:20-0:30"\
      \cf17 description\cf18 :\cf21  \cf18 >\cf21 \
        Establish narrator credibility and warmth. Listener must feel\
        "this person understands me" within 30 seconds.\
        Human narration: vocal warmth, measured pace, no rush.\
        AI narration: natural cadence, zero robotic artifacts.\
\
  \cf17 validation_rules\cf18 :\cf21 \
    \cf18 -\cf21  No exercise instructions in first 30 seconds (too soon for trust)\
    \cf18 -\cf21  No series references or "in this book you'll learn" lists\
    \cf18 -\cf21  No credentials dump (author bio comes later)\
    \cf18 -\cf21  Problem statement must use consumer_language_map terms\
    \cf18 -\cf21  Must match persona voice_tone and pace_bpm from persona config\
    \cf18 -\cf21  Must pass persona specificity score \cf18 >\cf21 = 0.70\
\
  \cf17 platform_specific\cf18 :\cf21 \
    \cf17 spotify\cf18 :\cf21 \
      \cf17 notes\cf18 :\cf21  \cf18 >\cf21 \
        First 30s IS the preview sample \'97 this is the conversion surface.\
        Design for earbuds during commute (not quiet room).\
        Include a save/follow prompt within first 10 minutes.\
        Skip rate feeds taste profile \'97 strong openings reduce skips.\
    \cf17 google_play\cf18 :\cf21 \
      \cf17 notes\cf18 :\cf21  \cf18 >\cf21 \
        Preview is configurable (20-100% of content).\
        First chapter is the de facto preview \'97 make it complete.\
    \cf17 audible\cf18 :\cf21 \
      \cf17 notes\cf18 :\cf21  \cf18 >\cf21 \
        Sample is typically ~5 minutes \'97 first 30s is the hook within that.\cf16 \cb1 \
\pard\pardeftab720\partightenfactor0

