\cf17 narration_assignment\cf18 :\cf16 \
  \cf17 hard_rules\cf18 :\cf16 \
    \cf18 -\cf16  \cf17 condition\cf18 :\cf16  book_type=flagship AND revenue_tier=1\
      \cf17 narration\cf18 :\cf16  human\
      \cf17 reason\cf18 :\cf16  "Tier 1 flagships drive discovery + revenue. AI voice\
