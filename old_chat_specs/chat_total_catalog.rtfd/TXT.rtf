\fs32 \cf2 \cb7 FTC Health Claims Rules\cb1 \
\cb7 The FTC requires that health-related benefit and safety claims be truthful, not misleading, and supported by competent and reliable scientific evidence (typically human clinical testing). "Not medical advice" disclaimers do NOT fix implied cure/treatment claims.\cb1 \
\
\pard\pardeftab720\partightenfactor0

\fs24 \cf5 \cb14 yaml\cb1 \
\pard\pardeftab720\partightenfactor0

\fs28 \cf15 \cb14 # config/compliance/ftc_health_claims.yaml\cf16 \
\pard\pardeftab720\partightenfactor0
\cf17 ftc_compliance\cf18 :\cf16 \
  \cf17 core_rule\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16     Health benefit claims must be supported by competent and reliable\
    scientific evidence. For therapeutic audiobook content, this means:\
\pard\pardeftab720\partightenfactor0
\cf21     position as SKILLS TRAINING, not TREATMENT.\cf16 \
\
  \cf17 banned_phrases\cf18 :\cf16 \
    \cf17 absolute_ban\cf18 :\cf16 \
      \cf18 -\cf16  \cf21 "cure"\cf16 \
      \cf18 -\cf16  \cf21 "cures"\cf16 \
      \cf18 -\cf16  \cf21 "will cure your"\cf16 \
      \cf18 -\cf16  \cf21 "heal your"\cf16 \
      \cf18 -\cf16  \cf21 "treatment for"\cf16 \
      \cf18 -\cf16  \cf21 "treats"\cf16 \
      \cf18 -\cf16  \cf21 "clinically proven to"\cf16 \
      \cf18 -\cf16  \cf21 "medically proven"\cf16 \
      \cf18 -\cf16  "doctor recommended" (unless actually doctor\cf18 -\cf16 recommended with documentation)\
      \cf18 -\cf16  "FDA approved" (never applicable to audiobooks)\
      \cf18 -\cf16  \cf21 "guaranteed to"\cf16 \
      \cf18 -\cf16  \cf21 "will eliminate your"\cf16 \
      \cf18 -\cf16  \cf21 "permanent relief"\cf16 \
      \cf18 -\cf16  \cf21 "get rid of your anxiety forever"\cf16 \
\
    \cf17 conditional_ban\cf18 :\cf16 \
      \cf18 -\cf16  \cf17 phrase\cf18 :\cf16  \cf21 "proven"\cf16 \
        \cf17 rule\cf18 :\cf16  \cf21 "Only with qualifier: 'evidence-based techniques' or 'research-supported approaches'"\cf16 \
      \cf18 -\cf16  \cf17 phrase\cf18 :\cf16  \cf21 "scientifically"\cf16 \
        \cf17 rule\cf18 :\cf16  \cf21 "Only as 'science-informed' or 'based on scientific research,' never 'scientifically proven to cure/treat'"\cf16 \
      \cf18 -\cf16  \cf17 phrase\cf18 :\cf16  \cf21 "therapy"\cf16 \
        \cf17 rule\cf18 :\cf16  \cf21 "Only as 'informed by therapy approaches like CBT' \'97 never 'this IS therapy'"\cf16 \
\
  \cf17 required_disclaimers\cf18 :\cf16 \
    \cf17 every_book\cf18 :\cf16 \
      \cf18 -\cf16  \cf17 position\cf18 :\cf16  copyright_page_and_audio_intro\
        \cf17 text\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16           This audiobook is for educational and informational purposes only.\
          It is not a substitute for professional medical advice, diagnosis,\
          or treatment. If you are experiencing a mental health crisis,\
\pard\pardeftab720\partightenfactor0
\cf21           please contact a healthcare professional or crisis service.\cf16 \
    \
    \cf17 somatic_content\cf18 :\cf16 \
      \cf18 -\cf16  \cf17 position\cf18 :\cf16  before_first_exercise\
        \cf17 text\cf18 :\cf16  \cf18 >\cf21 \
\pard\pardeftab720\partightenfactor0
\cf16           The practices in this book are designed to support general\
          wellbeing. If you have a medical condition, consult your\
\pard\pardeftab720\partightenfactor0
\cf21           healthcare provider before beginning any new practice.\cf16 \
\
  \cf17 safe_positioning_language\cf18 :\cf16 \
