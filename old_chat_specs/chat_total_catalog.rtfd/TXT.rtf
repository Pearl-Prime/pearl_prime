\
  \cf17 soft_rules\cf18 :\cf16 \
    \cf18 -\cf16  \cf17 condition\cf18 :\cf16  book_type=persona_variant AND revenue_tier \cf18 >\cf16 = 2\
      \cf17 narration\cf18 :\cf16  ai\
      \cf17 reason\cf18 :\cf16  \cf21 "Variants draft behind flagships. AI enables scale."\cf16 \
\
    \cf18 -\cf16  \cf17 condition\cf18 :\cf16  book_type=short_form\
      \cf17 narration\cf18 :\cf16  ai\
      \cf17 reason\cf18 :\cf16  \cf21 "Short-form at $4.99-$7.99 cannot support human economics."\cf16 \
\
    \cf18 -\cf16  \cf17 condition\cf18 :\cf16  persona_id=gen_alpha_students\
      \cf17 narration\cf18 :\cf16  ai\
      \cf17 reason\cf18 :\cf16  \cf21 "Gen Alpha on Spotify where AI narration is normalized."\cf16 \
\
  \cf17 quality_gates\cf18 :\cf16 \
    \cf18 -\cf16  IF narration=ai THEN first 30 seconds must pass human QA review\
