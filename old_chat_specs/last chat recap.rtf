## 2) Substitution engine logic (Python)\
\
### File: `phoenix_v4/exercises/overlay_substitution.py`\
\
```python\
from __future__ import annotations\
\
import re\
from dataclasses import dataclass\
from typing import Dict, List, Tuple\
\
\
CALL_OUT_PREFIXES_AHA = (\
    "Now, I want you",\
    "Now, I want to",\
    "Now, pause",\
    "Now, take a moment",\
    "Now, take a second",\
    "Now, let's",\
    "Now, stop",\
    "Now, reflect",\
    "Now, observe",\
    "Now, notice",\
    "Now, consider",\
    "Now, check",\
)\
\
# Integration prefixes (locked standard)\
CALL_OUT_PREFIXES_INTEGRATION = (\
    "Now, before you move on,",\
    "Now, as you return,",\
    "Now, for the next few minutes,",\
    "Now, as you go back to your day,",\
    "Now, keep it simple,",\
)\
\
BODY_REFERENCE_WORDS = (\
    "breath", "chest", "shoulders", "jaw", "neck", "rhythm", "tension",\
    "weight", "pressure", "warmth", "movement", "exhale", "inhale",\
    "body", "system", "nervous system",\
)\
\
# High-risk phrases to never introduce\
BANNED_OUTCOME_PHRASES = (\
    "you will", "this will", "guarantee", "cure", "heal", "fix",\
    "transform", "forever", "completely",\
)\
\
TOKEN_PATTERN = re.compile(r"\\\{([A-Z0-9_]+)\\\}")\
\
\
@dataclass(frozen=True)\
class OverlaySpec:\
    """Token-based overlay map: token -> replacement phrase."""\
    tokens: Dict[str, str]\
\
\
def _safe_token_substitute(text: str, token_map: Dict[str, str]) -> str:\
    """Replace \{TOKENS\} only. No blind string replacement."""\
    def repl(m: re.Match) -> str:\
        key = m.group(1)\
        return token_map.get(key, m.group(0))\
    return TOKEN_PATTERN.sub(repl, text)\
\
\
def _ordered_phrase_substitute(text: str, phrase_map: Dict[str, str]) -> str:\
    """\
    Legacy phrase-based replacement.\
    Substitutes longer phrases first to avoid partial overlaps.\
    Uses word-boundary-ish guards to reduce mid-word replacements.\
    """\
    items: List[Tuple[str, str]] = sorted(phrase_map.items(), key=lambda kv: len(kv[0]), reverse=True)\
    out = text\
    for src, dst in items:\
        # Replace as a phrase (not inside other words). This is conservative.\
        pattern = re.compile(rf"(?<!\\w)\{re.escape(src)\}(?!\\w)")\
        out = pattern.sub(dst, out)\
    return out\
\
\
def apply_persona_overlay(\
    base_sections: Dict[str, str],\
    persona: str,\
    apply_to_sections: List[str],\
    token_overlays: Dict[str, Dict[str, str]] | None = None,\
    phrase_overlays: Dict[str, Dict[str, str]] | None = None,\
) -> Dict[str, str]:\
    """\
    Applies persona overlays to selected sections only.\
    Priority:\
      1) token-based \{TOKENS\}\
      2) (optional) legacy phrase substitution\
    """\
    out = dict(base_sections)\
\
    tok_map = (token_overlays or \{\}).get(persona, \{\})\
    phr_map = (phrase_overlays or \{\}).get(persona, \{\})\
\
    for sec in apply_to_sections:\
        if sec not in out:\
            continue\
        text = out[sec]\
        if tok_map:\
            text = _safe_token_substitute(text, tok_map)\
        if phr_map:\
            text = _ordered_phrase_substitute(text, phr_map)\
        out[sec] = text\
\
    return out\
\
\
def validate_callout_prefix(section_name: str, text: str) -> List[str]:\
    errs: List[str] = []\
    if section_name == "aha_noticing":\
        if not text.startswith(CALL_OUT_PREFIXES_AHA):\
            errs.append("aha_noticing missing required callout prefix")\
    if section_name == "integration":\
        if not text.startswith(CALL_OUT_PREFIXES_INTEGRATION):\
            errs.append("integration missing required callout prefix")\
    return errs\
\
\
def validate_required_terms_for_aha(text: str) -> List[str]:\
    errs: List[str] = []\
    lower = text.lower()\
    if ("notice" not in lower) and ("might notice" not in lower):\
        errs.append("aha_noticing must contain 'notice' or 'might notice'")\
    if not any(w in lower for w in BODY_REFERENCE_WORDS):\
        errs.append("aha_noticing missing body reference word")\
    return errs\
\
\
def validate_banned_outcomes(text: str) -> List[str]:\
    lower = text.lower()\
    hit = [p for p in BANNED_OUTCOME_PHRASES if p in lower]\
    return [f"contains banned outcome phrase: \{h\}" for h in hit]\
```\
