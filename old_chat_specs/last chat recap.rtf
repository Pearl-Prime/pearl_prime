## 3) CI test to prevent overlay semantic breakage\
\
### File: `tools/ci/validate_exercise_sections.py`\
\
This validates **post-overlay** sections (i.e., what will be rendered).\
\
```python\
from __future__ import annotations\
\
import sys\
import yaml\
from pathlib import Path\
from typing import Dict, List, Tuple\
\
from phoenix_v4.exercises.overlay_substitution import (\
    apply_persona_overlay,\
    validate_callout_prefix,\
    validate_required_terms_for_aha,\
    validate_banned_outcomes,\
)\
\
# Adjust paths as needed\
EXERCISES_DIR = Path("SOURCE_OF_TRUTH/exercises_v4/approved")\
AHA_LIB_PATH = Path("SOURCE_OF_TRUTH/exercises_v4/aha_noticing_phoenix_standard.yaml")\
INTEGRATION_LIB_PATH = Path("SOURCE_OF_TRUTH/exercises_v4/integration_phoenix_standard.yaml")  # if you create it\
OVERLAYS_PATH = Path("SOURCE_OF_TRUTH/exercises_v4/persona_overlays.yaml")\
\
\
def _load_yaml(p: Path) -> Dict:\
    return yaml.safe_load(p.read_text(encoding="utf-8"))\
\
\
def _word_count(s: str) -> int:\
    return len([w for w in s.split() if w.strip()])\
\
\
def _validate_section(\
    section_name: str,\
    text: str,\
    min_words: int,\
    max_words: int | None,\
    require_aha_terms: bool = False,\
) -> List[str]:\
    errs: List[str] = []\
\
    if not text or not text.strip():\
        errs.append(f"\{section_name\} is empty")\
        return errs\
\
    wc = _word_count(text)\
    if wc < min_words:\
        errs.append(f"\{section_name\} word_count \{wc\} < min_words \{min_words\}")\
    if max_words is not None and wc > max_words:\
        errs.append(f"\{section_name\} word_count \{wc\} > max_words \{max_words\}")\
\
    errs.extend(validate_callout_prefix(section_name, text))\
    errs.extend(validate_banned_outcomes(text))\
\
    if require_aha_terms:\
        errs.extend(validate_required_terms_for_aha(text))\
\
    # Heuristic semantic-break guard: disallow odd \'93chemical performance pressure\'94 style collisions.\
    # This is intentionally a WARN unless you decide to hard fail.\
    lower = text.lower()\
    if "performance pressure may be chemical" in lower:\
        errs.append("warn: overlay collision phrase detected: 'performance pressure may be chemical'")\
\
    return errs\
\
\
def main() -> int:\
    overlays = _load_yaml(OVERLAYS_PATH)\
\
    # Support both token_overlays and phrase_overlays; you can store either or both.\
    token_overlays = overlays.get("token_overlays", \{\})\
    phrase_overlays = overlays.get("executive", \{\})  # if your overlays file is a flat map, adjust accordingly\
\
    # If overlays.yaml is structured as:\
    # persona_overlays:\
    #   executive: \{ lexical_shift: \{ ... \} \}\
    # then parse accordingly:\
    persona_overlays = overlays.get("persona_overlays", \{\})\
    phrase_overlays_map = \{\}\
    apply_to_sections = []\
    for persona, cfg in persona_overlays.items():\
        phrase_overlays_map[persona] = cfg.get("lexical_shift", \{\})\
        apply_to_sections = cfg.get("apply_to_sections", ["aha_noticing"])\
\
    failures: List[Tuple[str, str, str]] = []\
\
    for ex_file in EXERCISES_DIR.rglob("*.yaml"):\
        ex = _load_yaml(ex_file)\
        content = ex.get("content", \{\})\
\
        # Validate base sections exist\
        for sec in ("intro", "guided_practice", "aha_noticing", "integration"):\
            if sec not in content:\
                failures.append((str(ex_file), sec, "missing section"))\
                continue\
\
        # Validate for each persona overlay (optional)\
        for persona in ("executive", "gen_z", "healthcare"):\
            rendered = apply_persona_overlay(\
                base_sections=dict(content),\
                persona=persona,\
                apply_to_sections=apply_to_sections,\
                token_overlays=token_overlays,\
                phrase_overlays=phrase_overlays_map,\
            )\
\
            # AHA validation\
            for err in _validate_section(\
                "aha_noticing",\
                rendered["aha_noticing"],\
                min_words=40,  # registry min\
                max_words=150,\
                require_aha_terms=True,\
            ):\
                # callout is warn in registry; you can downgrade its severity here if desired\
                if err.startswith("aha_noticing missing required callout prefix"):\
                    failures.append((str(ex_file), f"aha_noticing[\{persona\}]", "warn: callout missing"))\
                else:\
                    failures.append((str(ex_file), f"aha_noticing[\{persona\}]", err))\
\
            # Integration validation (if you enforce now)\
            for err in _validate_section(\
                "integration",\
                rendered["integration"],\
                min_words=40,\
                max_words=150,\
                require_aha_terms=False,\
            ):\
                if err.startswith("integration missing required callout prefix"):\
                    failures.append((str(ex_file), f"integration[\{persona\}]", "warn: callout missing"))\
                else:\
                    failures.append((str(ex_file), f"integration[\{persona\}]", err))\
\
    if failures:\
        for fpath, sec, msg in failures:\
            print(f"\{fpath\} :: \{sec\} :: \{msg\}")\
        # If you want WARN-only behavior for overlay collisions, filter here.\
        return 1\
\
    print("OK: exercise sections validated (post-overlay)")\
    return 0\
\
\
if __name__ == "__main__":\
    raise SystemExit(main())\
