## 4) Wave-level AHA diversity guard (avoid repetition across books)\
\
### Rule (warn-first, not fail)\
\
* For each **compile wave** (N books), gather the rendered `aha_noticing` text (after persona overlay).\
* Compute similarity between AHA texts.\
* **Warn** if:\
\
  * any pair similarity \uc0\u8805  `0.85`, or\
  * more than `X%` of AHA blocks cluster into a single near-duplicate group.\
\
### Implementation: `tools/ci/validate_aha_diversity.py`\
\
```python\
from __future__ import annotations\
\
import re\
import json\
from pathlib import Path\
from typing import List, Tuple, Dict\
from collections import defaultdict\
\
# Input: compiled artifacts that include exercise sections (or a dump file).\
# Adjust to your actual compiled output structure.\
COMPILED_BOOKS_DIR = Path("artifacts/compiled_books")  # example\
SIM_THRESHOLD = 0.85\
CLUSTER_WARN_RATIO = 0.25  # 25% of wave in one near-duplicate cluster triggers warning\
\
\
def _normalize(text: str) -> List[str]:\
    # Normalize for similarity: lowercase, strip punctuation, remove extra whitespace.\
    t = text.lower()\
    t = re.sub(r"[^a-z0-9\\s]", " ", t)\
    t = re.sub(r"\\s+", " ", t).strip()\
    toks = [w for w in t.split() if w]\
    return toks\
\
\
def _char_ngrams(tokens: List[str], n: int = 4) -> set[str]:\
    s = " ".join(tokens)\
    if len(s) < n:\
        return \{s\} if s else set()\
    return \{s[i:i+n] for i in range(len(s) - n + 1)\}\
\
\
def _jaccard(a: set[str], b: set[str]) -> float:\
    if not a and not b:\
        return 1.0\
    if not a or not b:\
        return 0.0\
    return len(a & b) / len(a | b)\
\
\
def _load_wave_aha_texts() -> List[Tuple[str, str]]:\
    """\
    Returns [(book_id, aha_text), ...]\
    You need one canonical place where compiled books expose injected exercise sections.\
    """\
    out: List[Tuple[str, str]] = []\
    for p in COMPILED_BOOKS_DIR.rglob("*.json"):\
        data = json.loads(p.read_text(encoding="utf-8"))\
        book_id = data.get("book_id") or p.stem\
        # Expect compiled structure includes exercise sections; adjust key paths to your real schema\
        aha_blocks = data.get("exercise_aha_blocks", [])\
        for idx, txt in enumerate(aha_blocks):\
            out.append((f"\{book_id\}#aha\{idx:02d\}", txt))\
    return out\
\
\
def main() -> int:\
    items = _load_wave_aha_texts()\
    if len(items) < 2:\
        print("OK: not enough AHA blocks to evaluate diversity")\
        return 0\
\
    grams = \{k: _char_ngrams(_normalize(txt), 4) for k, txt in items\}\
\
    near_dupes: List[Tuple[str, str, float]] = []\
    parent = \{k: k for k, _ in items\}\
\
    def find(x: str) -> str:\
        while parent[x] != x:\
            parent[x] = parent[parent[x]]\
            x = parent[x]\
        return x\
\
    def union(a: str, b: str) -> None:\
        ra, rb = find(a), find(b)\
        if ra != rb:\
            parent[rb] = ra\
\
    keys = [k for k, _ in items]\
    for i in range(len(keys)):\
        for j in range(i + 1, len(keys)):\
            a, b = keys[i], keys[j]\
            sim = _jaccard(grams[a], grams[b])\
            if sim >= SIM_THRESHOLD:\
                near_dupes.append((a, b, sim))\
                union(a, b)\
\
    clusters: Dict[str, List[str]] = defaultdict(list)\
    for k in keys:\
        clusters[find(k)].append(k)\
\
    biggest = max((len(v) for v in clusters.values()), default=1)\
    ratio = biggest / max(1, len(keys))\
\
    if near_dupes or ratio >= CLUSTER_WARN_RATIO:\
        print("WARN: AHA diversity guard triggered")\
        if near_dupes:\
            for a, b, sim in near_dupes[:50]:\
                print(f"  near-dup: \{a\} ~ \{b\}  sim=\{sim:.2f\}")\
            if len(near_dupes) > 50:\
                print(f"  ... \{len(near_dupes)-50\} more")\
        print(f"  largest cluster size: \{biggest\}/\{len(keys)\} (\{ratio:.0%\})")\
        return 0  # warn-only by default\
\
    print("OK: AHA diversity looks healthy for this wave")\
    return 0\
\
\
if __name__ == "__main__":\
    raise SystemExit(main())\
```\
\
