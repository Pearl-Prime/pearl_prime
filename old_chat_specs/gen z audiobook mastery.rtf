class VoiceMode(Enum):\
    """\
    Voice modes for therapeutic audiobook generation.\
    \
    HIERARCHY:\
    1. WISDOM (default, safest)\
    2. RELATABLE_FP (advanced, Gen Z research-driven)\
    3. LEGACY_OPINION (deprecated, compatibility only)\
    """\
    \
    WISDOM = "wisdom_voice"\
    RELATABLE_FP = "relatable_first_person"\
    LEGACY_OPINION = "legacy_opinion"  # deprecated\
    \
    @classmethod\
    def get_default_for_persona(cls, persona: str) -> "VoiceMode":\
        """\
        Return recommended voice mode for persona.\
        \
        Gen Z personas \uc0\u8594  Relatable FP\
        All others \uc0\u8594  Wisdom Voice\
        """\
        \
        genz_personas = [\
            "gen_z_professionals",\
            "gen_z_students",\
            "gen_z_creatives"\
        ]\
        \
        if persona in genz_personas:\
            return cls.RELATABLE_FP\
        else:\
            return cls.WISDOM
