def _generate_chapter_content(self, chapter_num: int) -> str:\
    """\
    Generate full chapter content with enhanced chapter points.\
    """\
    \
    # Get chapter point\
    chapter_point = self.chapter_points[chapter_num]\
    \
    # Get exercise for this chapter\
    exercise = self.exercises[chapter_num]\
    \
    # Generate enhancement\
    enhancement = generate_chapter_point_enhancement(\
        chapter_point=chapter_point,\
        topic=self.book_topic,\
        exercise_name=exercise.name,\
        chapter_num=chapter_num\
    )\
    \
    # Build chapter template with enhancements\
    template_vars = \{\
        # Existing variables\
        "chapter_title": self.chapter_titles[chapter_num],\
        "chapter_hook": self.chapter_hooks[chapter_num],\
        # ... other existing vars ...\
        \
        # NEW: Enhancement variables\
        "chapter_point_seed": enhancement.seed,\
        "chapter_point_integration": enhancement.name_integration,\
        "story_hint": enhancement.story_reinforcement,\
        "carry_sentence_echo": enhancement.carry_sentence_echo,\
    \}\
    \
    # Hydrate template\
    chapter_content = self._hydrate_chapter_template(template_vars)\
    \
    return chapter_content
