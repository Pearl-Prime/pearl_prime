\f8 python\
def middle_slice_similarity_test(book_sample: list) -> dict:\
    """\
    Test Chapter 2-4 variation effectiveness.\
    Platform detection primarily scans middle chapters.\
    """\
    \
    results = \{\
        'pairwise_similarities': [],\
        'hotspots': [],\
        'mean_similarity': 0.0,\
        'max_similarity': 0.0\
    \}\
    \
    # Extract middle 400 words from Chapters 2-4\
    middle_slices = []\
    for book in book_sample:\
        slice_text = extract_chapters(book, [2, 3, 4])\
        slice_text = extract_middle_words(slice_text, 400)\
        middle_slices.append(slice_text)\
    \
    # Compute pairwise similarities\
    embeddings = [embed_text(slice) for slice in middle_slices]\
    \
    for i in range(len(embeddings)):\
        for j in range(i+1, len(embeddings)):\
            sim = cosine_similarity(embeddings[i], embeddings[j])\
            results['pairwise_similarities'].append(sim)\
            \
            if sim > 0.75:  # Flag hotspots\
                results['hotspots'].append(\{\
                    'book_a': book_sample[i]['book_id'],\
                    'book_b': book_sample[j]['book_id'],\
                    'similarity': sim\
                \})\
    \
    results['mean_similarity'] = np.mean(results['pairwise_similarities'])\
    results['max_similarity'] = np.max(results['pairwise_similarities'])\
    \
    return results
\f0 \
