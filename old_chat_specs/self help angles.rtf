    title_templates = load_templates('title')\
    subtitle_templates = load_templates('subtitle')\
    short_desc_templates = load_templates('short_description')\
    long_desc_templates = load_templates('long_description')\
    \
    # Deterministic selection per component\
    selections = \{\}\
    \
    for component, templates in [\
        ('title', title_templates),\
        ('subtitle', subtitle_templates),\
        ('short_description', short_desc_templates),\
        ('long_description', long_desc_templates)\
    ]:\
        seed = f"\{book_id\}_\{component\}"\
        hash_val = int(hashlib.sha256(seed.encode()).hexdigest(), 16)\
        template_id = list(templates.keys())[hash_val % len(templates)]\
        selections[f'\{component\}_template_id'] = template_id\
    \
    return selections
