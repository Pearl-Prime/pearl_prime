\f8 python\
def assign_origin_structure(book_id: str, persona_id: str) -> str:\
    """\
    Assign Chapter 2 origin structure deterministically.\
    \
    Maps based on persona characteristics:\
    - Younger personas (Gen Z, Gen Alpha) \uc0\u8594  origin_moment (relatable)\
    - Professional personas \uc0\u8594  origin_timeline (clear progression)\
    - High-sensitivity personas \uc0\u8594  origin_gradual (gentle)\
    - Long-term struggle personas \uc0\u8594  origin_always (validation)\
    """\
    \
    # Persona \uc0\u8594  origin structure mapping\
    PERSONA_ORIGIN_MAP = \{\
        'gen_z_professionals': 'origin_timeline',\
        'gen_z_students': 'origin_moment',\
        'gen_alpha': 'origin_gradual',\
        'healthcare_workers': 'origin_timeline',\
        'burned_out_creators': 'origin_always',\
        'anxious_parents': 'origin_gradual',\
        # ... etc\
    \}\
    \
    # Deterministic fallback if persona not mapped\
    if persona_id not in PERSONA_ORIGIN_MAP:\
        origin_structures = ['origin_timeline', 'origin_moment', 'origin_gradual', 'origin_always']\
        seed = f"\{book_id\}_origin"\
        hash_val = int(hashlib.sha256(seed.encode()).hexdigest(), 16)\
        return origin_structures[hash_val % len(origin_structures)]\
    \
    return PERSONA_ORIGIN_MAP[persona_id]
