### 
\f7 \uc0\u9888 \u65039 
\f0  CRITICAL: Saturation Constraints\
\

\f8 yaml\
motif_constraints:\
  max_per_chapter: 2          # Hard limit\
  min_distance_words: 250     # Minimum spacing\
  max_total_per_book: 12      # Absolute maximum
