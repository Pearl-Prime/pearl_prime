def generate_phoenix_omega_book_enhanced(values_file):\
    """\
    Generate Phoenix Omega book with all Phase 3.5 enhancements.\
    \
    Phase 3.5 adds:\
    - Chapter 2 origin structure variation\
    - Mechanism emphasis layer\
    - Recurring motif system\
    - Metadata variation\
    """\
    \
    # 1. Load base values\
    values = load_values(values_file)\
    \
    # 2. Assign all variation layers (if not provided)\
    if 'structure_id' not in values:\
        values['structure_id'] = assign_structure(\
            persona_id=values['persona_id'],\
            book_id=values['book_id']\
        )\
    \
    if 'origin_structure' not in values:\
        values['origin_structure'] = assign_origin_structure(\
            persona_id=values['persona_id'],\
            book_id=values['book_id']\
        )\
    \
    if 'mechanism_emphasis' not in values:\
        values['mechanism_emphasis'] = assign_mechanism_emphasis(\
            persona_id=values['persona_id'],\
            topic_id=values['topic_id'],\
            book_id=values['book_id']\
        )\
    \
    if 'motif_id' not in values:\
        values['motif_id'] = assign_motif(\
            structure_id=values['structure_id'],\
            emphasis=values['mechanism_emphasis'],\
            book_id=values['book_id']\
        )\
    \
    if 'metadata' not in values:\
        values['metadata'] = assign_metadata(\
            persona_id=values['persona_id'],\
            topic_id=values['topic_id'],\
            structure_id=values['structure_id'],\
            book_id=values['book_id']\
        )\
    \
    # 3. Initialize injectors\
    motif_injector = MotifInjector('data/config/recurring_motif_bank.yaml')\
    token_injector = TokenOverlayInjector(\
        'data/config/recognition_token_banks.yaml',\
        'data/config/overlay_injection_rules.yaml'\
    )\
    \
    # 4. Generate all chapters\
    chapters = []\
    for chapter_num in range(1, 13):\
        # Generate base chapter\
        if chapter_num == 1:\
            chapter = generate_chapter_1_with_structure(values)\
        elif chapter_num == 2:\
            chapter = generate_chapter_2_with_origin(values)\
        elif chapter_num == 3:\
            chapter = generate_chapter_3_with_emphasis(values)\
        elif chapter_num == 12:\
            chapter = generate_chapter_12_with_structure(values)\
        else:\
            chapter = generate_chapter_standard(chapter_num, values)\
        \
        # Apply motif injection\
        chapter = motif_injector.inject_motif(\
            chapter_content=chapter,\
            chapter_num=chapter_num,\
            motif_id=values['motif_id']\
        )\
        \
        # Apply token overlays (if applicable)\
        if chapter_num == 1 and should_use_tokens(values['persona_id']):\
            for beat in [2, 3, 6]:\
                chapter = token_injector.inject_overlays(\
                    chapter=1,\
                    beat=beat,\
                    persona_id=values['persona_id'],\
                    book_id=values['book_id'],\
                    existing_content=chapter\
                )\
        \
        chapters.append(chapter)\
    \
    # 5. Generate metadata\
    metadata = generate_metadata_from_templates(\
        templates=values['metadata'],\
        atoms=values['atoms']\
    )\
    \
    # 6. Assemble final book\
    book = \{\
        'metadata': metadata,\
        'chapters': chapters,\
        'manifest': generate_manifest(values)\
    \}\
    \
    # 7. Output\
    write_book_to_file(book, output_path)\
    write_manifest(book['manifest'], manifest_path)\
    \
    return book
