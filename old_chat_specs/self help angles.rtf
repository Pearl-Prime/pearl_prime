\f8 python\
def assign_series(persona_id: str, topic_id: str) -> str:\
    """\
    Assign series based on persona + topic.\
    \
    Series is deterministic per persona cluster.\
    """\
    \
    # Persona \uc0\u8594  series mapping\
    PERSONA_SERIES_MAP = \{\
        'gen_z_professionals': 'recognition_series',\
        'burned_out_creators': 'creators_burnout_series',\
        'gen_z_students': 'quick_reset_series',\
        'gen_alpha': 'quick_reset_series',\
        'healthcare_workers': 'recognition_series',\
        'anxious_parents': 'quick_reset_series',\
        # ... etc\
    \}\
    \
    return PERSONA_SERIES_MAP.get(persona_id, 'recognition_series')\
\
\
def apply_series_bias(series_id: str, book_id: str) -> dict:\
    """\
    Apply series selection bias to structure assignment.\
    \
    Biases selection toward series-preferred structures,\
    but doesn't hard-code them (maintains variety).\
    """\
    \
    series = load_series_definition(series_id)\
    \
    # Bias structure selection\
    opening_structure = weighted_select(\
        options=ALL_OPENING_STRUCTURES,\
        preferred=series['selection_bias']['preferred_opening_structures'],\
        bias_weight=0.7,  # 70% chance of preferred, 30% any\
        seed=f"\{book_id\}_opening"\
    )\
    \
    # Bias motif selection\
    motif = weighted_select(\
        options=ALL_MOTIFS,\
        preferred=series['selection_bias']['preferred_motifs'],\
        bias_weight=0.7,\
        seed=f"\{book_id\}_motif"\
    )\
    \
    # Bias emphasis selection\
    emphasis = weighted_select(\
        options=ALL_EMPHASES,\
        preferred=series['selection_bias']['preferred_emphasis'],\
        bias_weight=0.7,\
        seed=f"\{book_id\}_emphasis"\
    )\
    \
    # Bias origin selection\
    origin = weighted_select(\
        options=ALL_ORIGINS,\
        preferred=series['selection_bias']['preferred_origin'],\
        bias_weight=0.7,\
        seed=f"\{book_id\}_origin"\
    )\
    \
    return \{\
        'series_id': series_id,\
        'opening_structure': opening_structure,\
        'motif_id': motif,\
        'mechanism_emphasis': emphasis,\
        'origin_structure': origin,\
        'metadata_tone': series['metadata_tone']\
    \}
