def assign_metadata_with_drift_check(\
    persona_id: str,\
    topic_id: str,\
    book_id: str,\
    recent_metadata_pool: list\
) -> dict:\
    """\
    Prevent metadata clustering via semantic similarity guard.\
    """\
    \
    max_attempts = 5\
    similarity_threshold = 0.85\
    \
    for attempt in range(max_attempts):\
        metadata = assign_metadata(persona_id, topic_id, book_id + f"_attempt_\{attempt\}")\
        new_embedding = generate_metadata_embedding(metadata)\
        \
        if recent_metadata_pool:\
            pool_mean = compute_mean_embedding(recent_metadata_pool)\
            similarity = cosine_similarity(new_embedding, pool_mean)\
            \
            if similarity < similarity_threshold:\
                return metadata\
        else:\
            return metadata\
    \
    return rotate_to_distinct_template(persona_id, topic_id, book_id)\
\
def generate_metadata_embedding(metadata: dict) -> np.ndarray:\
    combined = f"\{metadata['title']\} \{metadata['short_description']\}"\
