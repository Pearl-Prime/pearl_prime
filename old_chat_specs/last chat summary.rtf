File: phoenix_v3/policies/story_slot_policy.yaml (NEW)\
\
Purpose: Enforce narrative governance - prevent story overuse, clustering, and drift.\
\
Schema:\
\
chapters:\
  1:\
    max_stories: 1\
    allowed_layers: [L1]\
    allowed_positions: [after_para_2, after_para_3]\
    forbidden: false\
\
  2:\
    max_stories: 1\
    allowed_layers: [L1, L2]\
    allowed_positions: [after_para_3, after_section_1]\
    forbidden: false\
\
  4:\
    max_stories: 1\
    allowed_layers: [L2]\
    allowed_positions: [after_section_2]\
    forbidden: false\
\
  7:\
    max_stories: 1\
    allowed_layers: [L3]\
    allowed_positions: [after_section_3]\
    forbidden: false\
\
  12:\
    max_stories: 0\
    forbidden: true  # No stories in final chapter\
\
default:\
  max_stories: 0  # If chapter not listed, no stories allowed\
