# Registry-based plan (size-aware, default medium)python3 phoenix_v4/tools/generate_full_plan.py \\  --format_type standard_book --book_size medium --teacher_mode off \\  --output phoenix_v4/plans/demo_plan.yaml# Short standard_bookpython3 phoenix_v4/tools/generate_full_plan.py \\  --format_type standard_book --book_size short \\  --topic anxiety --persona gen_z_professionals \\  --output phoenix_v4/plans/anxiety_genz_short.yaml# 7-day format, longpython3 phoenix_v4/tools/generate_full_plan.py \\  --format_type seven_day_reset --book_size long \\  --output phoenix_v4/plans/seven_day_demo.yaml# Registry mode (no format_type), medium, with story + exercise slotspython3 phoenix_v4/tools/generate_full_plan.py \\  --book_size medium --output phoenix_v4/plans/registry_demo.yaml\
