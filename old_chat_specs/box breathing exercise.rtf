\fs32 \cf0 \cb7 # Chapter Role Map\
# Prevents intra-chapter chaos by assigning roles\
#\
# Purpose: Instead of every chapter doing everything,\
# define roles that limit what layers can appear\
\
version: "1.0"\
\
# Role Definitions\
roles:\
  Teach:\
    layers_allowed: [concept]\
    max_exercises: 0\
    max_reflections: 0\
    description: "Conceptual teaching only"\
  \
  Practice:\
    layers_allowed: [exercise]\
    max_exercises: 1\
    max_reflections: 0\
    description: "Exercise instruction only"\
  \
  Integrate:\
    layers_allowed: [reflection]\
    max_exercises: 0\
    max_reflections: 2\
    description: "Reflection and integration"\
  \
  Teach+Practice:\
    layers_allowed: [concept, exercise]\
    max_exercises: 1\
    max_reflections: 0\
    description: "Concept + exercise"\
  \
  Practice+Reflect:\
    layers_allowed: [exercise, reflection]\
    max_exercises: 1\
    max_reflections: 1\
    description: "Exercise + reflection"\
  \
  Full:\
    layers_allowed: [concept, exercise, reflection]\
    max_exercises: 1\
    max_reflections: 2\
    description: "All layers allowed (use sparingly)"\
\
# Chapter Role Assignments (Phoenix Omega 12-chapter structure)\
chapter_assignments:\
  # Recognition phase\
  1:\
    role: Teach\
    description: "Introduce pattern"\
  \
  2:\
    role: Teach\
    description: "Origin story"\
  \
  3:\
    role: Teach\
    description: "Pattern explanation"\
  \
  # Practice phase\
  4:\
    role: Teach+Practice\
    description: "First exercise"\
  \
  5:\
    role: Practice\
    description: "Second exercise"\
  \
  6:\
    role: Integrate\
    description: "Pattern recognition"\
  \
  7:\
    role: Practice\
    description: "Third exercise"\
  \
  8:\
    role: Practice\
    description: "Fourth exercise"\
  \
  # Integration phase\
  9:\
    role: Integrate\
    description: "Complicate phase"\
  \
  10:\
    role: Integrate\
    description: "Recovery"\
  \
  11:\
    role: Integrate\
    description: "Identity shift"\
  \
  12:\
    role: Integrate\
    description: "Closure"\
\
# Validation\
validation:\
  strict_role_enforcement: true\
  allow_role_override: false  # If true, can override per book\cb1 \
