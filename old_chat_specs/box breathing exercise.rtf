\fs32 \cf0 \cb7 # FORBIDDEN WORDS IN TEMPLATES\
\
## PURPOSE\
Templates must remain topic-agnostic.\
Topic-specific content enters ONLY through variables.\
\
## TOPIC WORDS (NEVER IN TEMPLATES)\
\
### Emotions/States\
- anxiety\
- anxious\
- grief\
- grieving\
- depressed\
- depression\
- burnout\
- burned out\
- trauma\
- traumatized\
- ADHD\
- panic\
- worried\
- sad\
- angry\
\
### Clinical Terms\
- disorder\
- diagnosis\
- symptom\
- condition\
- treatment\
- therapy\
- patient\
- client\
\
### Solutions\
- cure\
- fix\
- heal\
- overcome\
- conquer\
- defeat\
- eliminate\
- get rid of\
\
### Premature Resolution\
- calm\
- peace\
- relief\
- better\
- recovered\
- healed\
- fixed\
- solved\
\
## ALLOWED (STRUCTURAL LANGUAGE)\
\
### State Descriptors (via variables only)\
- 
\f9\fs28 \cb11 \{current_emotional_state\}
\f0\fs32 \cb7 \
- 
\f9\fs28 \cb11 \{desired_state\}
\f0\fs32 \cb7 \
- 
\f9\fs28 \cb11 \{book_topic\}
\f0\fs32 \cb7 \
- 
\f9\fs28 \cb11 \{core_feeling\}
\f0\fs32 \cb7 \
\
### Action Language\
- act\
- do\
- move\
- choose\
- decide\
- live\
- show up\
- be present\
\
### Pattern Language\
- sentence\
- pattern\
- loop\
- rule\
- strategy\
- waiting\
- permission\
\
### Coexistence Language\
- alongside\
- while\
- with\
- even though\
- and\
- both\
\
## ENFORCEMENT\
\
### Red Flag Detection\
If ANY forbidden word appears in a template file (not in 
\f9\fs28 \cb11 \{variable\}
\f0\fs32 \cb7  slots):\
- **REJECT immediately**\
- **Log violation**\
- **Block generation**\
\
### Validation Test\
\pard\pardeftab720\partightenfactor0

\f9 \cf0 bash\
# Check template for topic-specific words\
grep -E "(anxiety|grief|burnout|depressed|trauma)" template.md\
# If match found \uc0\u8594  FAIL
\f0 \
\
### Developer Checklist\
Before committing any template change:\
- [ ] No emotion/state words (except in variable slots)\
- [ ] No clinical terms\
- [ ] No solution language\
- [ ] No cure promises\
- [ ] Beat structure preserved\
- [ ] Only 
\f9\fs28 \cb11 \{variable\}
\f0\fs32 \cb7  slots contain topic content\
\
## WHY THIS MATTERS\
\
**If templates contain topic words:**\
- System breaks (can't generate grief books from anxiety template)\
- Platform flags similarity (all books sound the same)\
- Writers burn out (rewriting structure for every topic)\
\
**If templates stay generic:**\
- One spine 
\f6 \uc0\u8594 
\f0  infinite topics\
- One engine 
\f6 \uc0\u8594 
\f0  many books\
- One validation 
\f6 \uc0\u8594 
\f0  consistent quality\
- Platform sees differentiation\
\
## THE TEST\
\
Can you replace 
\f9\fs28 \cb11 \{book_topic\}
\f0\fs32 \cb7  with ANY internal state and still have a coherent structure?\
\
**Good template:**\

\f9 What if the problem isn't the \{current_emotional_state\}?
\f0 \
\
**Bad template:**\

\f9 What if the problem isn't the anxiety?
\f0 \
\
One works for grief, burnout, ADHD, etc.\
One only works for anxiety.\
\
## FINAL RULE\
\
**Templates = Structure**\
**Variables = Content**\
\
Never confuse them. \
\
# PERSONA \'d7 TOPIC VARIABLE SCHEMA v1.0\
# Single source of truth for all chapter template hydration\
# This schema ensures deterministic, complete, and safe book generation\
\
version: "1.0"\
schema_type: "persona_topic_variables"\
purpose: "Defines all variables required to hydrate 12-chapter therapeutic audiobook templates"\
\
# ==============================================================================\
# GLOBAL VARIABLES (Required for ALL chapters)\
# ==============================================================================\
\
global:\
  persona:\
    type: object\
    required: true\
    description: "Core persona identification and calibration"\
    properties:\
      id:\
        type: string\
        required: true\
        description: "Unique persona identifier (e.g., 'gen_z_professionals', 'nyc_executives')"\
        validation: "Must exist in unified_personas.yaml"\
      \
      name:\
        type: string\
        required: true\
        description: "Display name for persona"\
        example: "Gen Z Professionals"\
      \
      authority_tolerance:\
        type: enum\
        required: true\
        options: ["low", "medium", "high"]\
        description: "How much explanation/authority this persona tolerates"\
        examples:\
          low: "Gen Z (peer-level only, no lecturing)"\
          medium: "RN (warm colleague, not therapist)"\
          high: "NYC Exec (can handle complexity)"\
      \
      language_register:\
        type: enum\
        required: true\
        options: ["conversational", "professional", "clinical"]\
        description: "Vocabulary and sentence complexity level"\
      \
      attention_span:\
        type: enum\
        required: true\
        options: ["short", "medium", "long"]\
        description: "Practice length tolerance and paragraph length"\
        impact:\
          short: "2-3 line paragraphs, <2min practices"\
          medium: "4-5 line paragraphs, 2-3min practices"\
          long: "6+ line paragraphs, 3-5min practices"\
\
  topic:\
    type: object\
    required: true\
    description: "Core topic/emotional state being addressed"\
    properties:\
      id:\
        type: string\
        required: true\
        description: "Topic identifier"\
        examples: ["anxiety", "grief", "burnout", "depression"]\
        validation: "Must NOT appear verbatim in templates (topic-agnostic rule)"\
      \
      book_title:\
        type: string\
        required: true\
        description: "Full book title"\
        example: "Acting While Anxious"\
      \
      book_subtitle:\
        type: string\
        required: false\
        description: "Optional subtitle"\
\
  core:\
    type: object\
    required: true\
    description: "Core thesis variables that appear across multiple chapters"\
    properties:\
      core_sentence:\
        type: string\
        required: true\
        description: "The waiting statement that runs the person's life"\
        examples:\
          anxiety: "Once I'm not anxious, then I'll do it"\
          grief: "Once I'm done grieving, then I'll live again"\
          burnout: "Once I'm less depleted, then I can care again"\
        validation: "Must be quotable, first-person, future-conditional"\
      \
      current_emotional_state:\
        type: string\
        required: true\
        description: "How they feel now (variable slot, not hardcoded)"\
        examples: ["anxious", "grieving", "depleted", "overwhelmed"]\
      \
      desired_state:\
        type: string\
        required: true\
        description: "What they're waiting to feel"\
        examples: ["calm", "healed", "energized", "confident"]\
      \
      core_action:\
        type: string\
        required: true\
        description: "What they're not allowing themselves to do"\
        examples: ["post", "reach out", "care", "decide"]\
      \
      life_domain:\
        type: string\
        required: true\
        description: "What area of life is affected"\
        examples: ["social life", "relationships", "work", "leadership"]\
\
# ==============================================================================\
# CHAPTER 1: HOOK + RECOGNITION\
# ==============================================================================\
\
chapter_1:\
  function: "Make pattern undeniable in first 3 minutes"\
  emotion_state: "recognition"\
  exercise_permission: false\
  \
  required_variables:\
    time_duration:\
      type: string\
      required: true\
      description: "How long they've been saying the sentence"\
      examples: ["years", "months", "your whole adult life"]\
    \
    sentence_variations:\
      type: list[string]\
      required: true\
      min_count: 3\
      max_count: 3\
      description: "Three alternative phrasings of core_sentence"\
      validation: "Must maintain same meaning, different words"\
    \
    moments:\
      type: list[object]\
      required: true\
      min_count: 3\
      max_count: 5\
      description: "Specific micro-moments where they said the sentence"\
      properties:\
        context:\
          type: string\
          required: true\
          description: "Brief label for the situation"\
          example: "Last week, scrolling Instagram"\
        situation:\
          type: string\
          required: true\
          description: "Full situational description (2-3 sentences)"\
          validation: "Must be specific, recognizable, persona-appropriate"\
    \
    cost_examples:\
      type: list[object]\
      required: true\
      min_count: 4\
      max_count: 4\
      description: "What they're not doing while they wait"\
      properties:\
        label:\
          type: string\
          required: true\
          description: "Category of cost"\
          examples: ["The Text You Didn't Send", "The Decision You Deferred"]\
        detail:\
          type: string\
          required: true\
          description: "Specific description of the cost (2-3 sentences)"\
    \
    life_domain_activity:\
      type: string\
      required: true\
      description: "What continues moving without them"\
      examples: ["life", "work", "the conversation", "the opportunity"]\
    \
    perceived_virtues:\
      type: list[string]\
      required: true\
      min_count: 3\
      max_count: 3\
      description: "What they think the sentence is about (wrong guesses)"\
      examples: ["being thoughtful", "being careful", "being responsible"]\
    \
    reality_statements:\
      type: list[string]\
      required: true\
      min_count: 2\
      max_count: 2\
      description: "What it's actually about (the truth)"\
      validation: "Must reframe from virtue to mechanism"\
\
# ==============================================================================\
# CHAPTER 2: VALIDATION\
# ==============================================================================\
\
