def lint_word_count(text: str, min_words: int = 60, max_words: int = 150) -> List[LintError]:\
    """Body must be 60-150 words (system atom rule)."""\
    errs: List[LintError] = []\
    if not text or not text.strip():\
        return errs\
    n = len(text.strip().split())\
    if n < min_words:\
        errs.append(LintError("word_count", f"body has \{n\} words (min \{min_words\})"))\
    elif n > max_words:\
        errs.append(LintError("word_count", f"body has \{n\} words (max \{max_words\})"))\
    return errs\
