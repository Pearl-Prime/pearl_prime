#!/usr/bin/env python3\
"""\
Execute system_atom prompt packs: LLM write 
\f1 \uc0\u8594 
\f0  story_atom_lint 
\f1 \uc0\u8594 
\f0  write vNN.txt + vNN_meta.yaml 
\f1 \uc0\u8594 
\f0  fingerprint.\
\
Hard rules (enforced by story_atom_lint):\
- Third-person only, AVC-1 required, role semantics, 60-150 words, no advice/doctrine/biography.\
- status forced to provisional.\
\
Can be run standalone (with --writer=callback or env) or by Golden Phoenix agent.\
"""\
\
from __future__ import annotations\
\
import json\
import re\
import sys\
from pathlib import Path\
from typing import Any, Callable, Dict, List, Optional, Tuple\
\
