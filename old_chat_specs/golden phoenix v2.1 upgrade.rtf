def execute_system_atom_packs(\
    repo_root: Path,\
    writer: Optional[Callable[[str, Dict[str, str]], Tuple[Optional[str], Optional[Dict[str, Any]]]]] = None,\
    progress_cb: Optional[Callable[[str], None]] = None,\
    pack_glob: str = "**/*.md",\
) -> Dict[str, Any]:\
    """\
    Discover packs under prompts/v4/system_atoms, run writer 
\f1 \uc0\u8594 
\f0  lint 
\f1 \uc0\u8594 
\f0  write 
\f1 \uc0\u8594 
\f0  fingerprint.\
    writer(pack_text, parsed) -> (body_text, meta_dict) or (None, None) to skip.\
    Returns \{"written": N, "rejected": M, "rejection_reasons": \{...\}, "skipped": K\}.\
    """\
    cb = progress_cb or (lambda _: None)\
    written = 0\
    rejected = 0\
    skipped = 0\
    rejection_reasons: Dict[str, int] = \{\}\
\
    if not PACK_ROOT.exists():\
        cb("No system_atoms pack root; skipping.")\
        return \{"written": 0, "rejected": 0, "rejection_reasons": \{\}, "skipped": 0\}\
\
    pack_files = list(PACK_ROOT.glob(pack_glob))\
    if not pack_files:\
        cb("No system_atom packs found.")\
        return \{"written": 0, "rejected": 0, "rejection_reasons": \{\}, "skipped": 0\}\
\
    for pack_path in sorted(pack_files):\
        if not pack_path.is_file() or pack_path.suffix != ".md":\
            continue\
        text = pack_path.read_text(encoding="utf-8")\
        parsed = _parse_pack(text)\
        persona = parsed.get("persona", "").strip()\
        topic = parsed.get("topic", "").strip()\
        engine = parsed.get("engine", "legacy").strip()\
        role = parsed.get("role", "").strip().lower()\
        save_path = parsed.get("save_path", "").strip()\
        filename_body = parsed.get("filename_body", "v01.txt").strip()\
        filename_meta = parsed.get("filename_meta", "v01_meta.yaml").strip()\
\
        if not persona or not topic or not role or not save_path:\
            skipped += 1\
            continue\
\
        save_dir = repo_root / save_path\
        next_v = _next_variant_num(save_dir)\
        body_file = f"v\{next_v:02d\}.txt"\
        meta_file = f"v\{next_v:02d\}_meta.yaml"\
\
        if writer is None:\
            cb(f"Skip (no writer): \{pack_path.relative_to(PACK_ROOT)\}")\
            skipped += 1\
            continue\
\
        try:\
            body_text, meta_dict = writer(text, parsed)\
        except Exception as e:\
            rejected += 1\
            rejection_reasons["writer_error"] = rejection_reasons.get("writer_error", 0) + 1\
            cb(f"Reject (writer): \{pack_path.name\} \'97 \{e\}")\
            continue\
\
        if not body_text or not meta_dict:\
            skipped += 1\
            continue\
\
        point = (meta_dict.get("point") or "").strip()\
        if not point:\
            rejected += 1\
            rejection_reasons["AVC-1 missing"] = rejection_reasons.get("AVC-1 missing", 0) + 1\
            cb(f"Reject (no point): \{pack_path.name\}")\
            continue\
\
        if _point_already_used_atom(repo_root, persona, topic, role, point):\
            cb(f"Skip (point exists): \{persona\}/\{topic\}/\{role\}")\
            skipped += 1\
            continue\
        if _situation_used_atom(repo_root, persona, topic, role, body_text):\
            cb(f"Skip (situation exists): \{persona\}/\{topic\}/\{role\}")\
            skipped += 1\
            continue\
\
        atom = \{\
            "text": body_text,\
            "point": point,\
            "reversal_line": meta_dict.get("reversal_line") or "",\
            "stakes": meta_dict.get("stakes") or "",\
            "role": role,\
        \}\
        if not lint_story_atom:\
            rejection_reasons["lint_unavailable"] = rejection_reasons.get("lint_unavailable", 0) + 1\
            rejected += 1\
            continue\
        errs = lint_story_atom(atom)\
        if errs:\
            rejected += 1\
            for e in errs:\
                key = getattr(e, "rule", str(e)) if hasattr(e, "rule") else "lint"\
                rejection_reasons[key] = rejection_reasons.get(key, 0) + 1\
            cb(f"Reject (lint): \{pack_path.name\} \'97 \{errs[0]\}")\
            continue\
\
        meta_out = \{\
            "point": point,\
            "reversal_line": meta_dict.get("reversal_line") or None,\
            "stakes": meta_dict.get("stakes") or None,\
            "status": "provisional",\
        \}\
        save_dir.mkdir(parents=True, exist_ok=True)\
        (save_dir / body_file).write_text(body_text.strip(), encoding="utf-8")\
        if yaml:\
            (save_dir / meta_file).write_text(\
                yaml.dump(meta_out, default_flow_style=False, allow_unicode=True),\
                encoding="utf-8",\
