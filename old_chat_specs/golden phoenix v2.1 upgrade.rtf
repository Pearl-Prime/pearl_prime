def main() -> None:\
    import argparse\
    ap = argparse.ArgumentParser(description="Execute system_atom packs: lint, write, fingerprint.")\
    ap.add_argument("--dry-run", action="store_true", help="Only discover packs, do not write")\
    args = ap.parse_args()\
    writer = None if args.dry_run else _default_writer\
    result = execute_system_atom_packs(REPO_ROOT, writer=writer, progress_cb=print)\
    print(f"Result: written=\{result['written']\}, rejected=\{result['rejected']\}, skipped=\{result['skipped']\}")\
    if result["rejection_reasons"]:\
        print("Rejection reasons:", result["rejection_reasons"])\
