if str(REPO_ROOT) not in sys.path:\
    sys.path.insert(0, str(REPO_ROOT))\
\
try:\
    import yaml\
except ImportError:\
    yaml = None\
\
PACK_ROOT = REPO_ROOT / "prompts" / "v4" / "system_atoms"\
SOT_ATOMS = REPO_ROOT / "SOURCE_OF_TRUTH" / "data" / "story_bank" / "story_atoms"\
\
# Lint and fingerprint\
try:\
    from phoenix_v4.ci.story_atom_lint import lint_story_atom\
except ImportError:\
    lint_story_atom = None\
try:\
    from phoenix_v4.ci.repetition_fingerprint import (\
        point_fingerprint,\
        situation_fingerprint,\
    )\
except ImportError:\
    point_fingerprint = None\
    situation_fingerprint = None\
\
\
def _parse_pack(text: str) -> Dict[str, str]:\
    out: Dict[str, str] = \{\}\
    for line in text.splitlines():\
        line = line.strip()\
        if not line or not line[0].isalpha():\
            continue\
        if ":" in line:\
            k, v = line.split(":", 1)\
            out[k.strip().lower().replace("-", "_")] = v.strip()\
    return out\
\
\
def _next_variant_num(dir_path: Path) -> int:\
    if not dir_path.exists():\
        return 1\
    n = 0\
    for f in dir_path.iterdir():\
        if f.suffix == ".txt" and f.stem.startswith("v"):\
            try:\
                n = max(n, int(f.stem[1:], 10))\
            except ValueError:\
                pass\
    return n + 1\
\
\
# System-atom fingerprint storage: story_bank/story_atoms/.fingerprints.json\
def _atom_fingerprints_path(repo_root: Path) -> Path:\
    return repo_root / "SOURCE_OF_TRUTH" / "data" / "story_bank" / "story_atoms" / ".fingerprints.json"\
\
\
def _load_atom_fingerprints(repo_root: Path) -> Dict[str, Any]:\
    path = _atom_fingerprints_path(repo_root)\
    if not path.exists():\
        return \{"point_hashes": \{\}, "situation_hashes": \{\}\}\
    try:\
        data = json.loads(path.read_text(encoding="utf-8"))\
        data.setdefault("point_hashes", \{\})\
        data.setdefault("situation_hashes", \{\})\
        return data\
    except Exception:\
        return \{"point_hashes": \{\}, "situation_hashes": \{\}\}\
\
\
def _save_atom_fingerprints(repo_root: Path, data: Dict[str, Any]) -> None:\
    path = _atom_fingerprints_path(repo_root)\
    path.parent.mkdir(parents=True, exist_ok=True)\
    path.write_text(json.dumps(data, indent=2), encoding="utf-8")\
\
\
def _atom_key(persona: str, topic: str, role: str) -> str:\
    return f"\{persona\}/\{topic\}/\{role\}"\
\
\
def _point_already_used_atom(repo_root: Path, persona: str, topic: str, role: str, point: str) -> bool:\
    if not point_fingerprint or not point:\
        return False\
    data = _load_atom_fingerprints(repo_root)\
    key = _atom_key(persona, topic, role)\
    hashes = (data.get("point_hashes") or \{\}).get(key) or \{\}\
    h = point_fingerprint(point)\
    return h in hashes\
\
\
def _situation_used_atom(repo_root: Path, persona: str, topic: str, role: str, body: str) -> bool:\
    if not situation_fingerprint or not body:\
        return False\
    data = _load_atom_fingerprints(repo_root)\
    key = _atom_key(persona, topic, role)\
    hashes = (data.get("situation_hashes") or \{\}).get(key) or \{\}\
    h = situation_fingerprint(body)\
    return h in hashes\
\
\
def _add_atom_fingerprints(\
    repo_root: Path, persona: str, topic: str, role: str, point: str, body: str, variant_id: str\
) -> None:\
    data = _load_atom_fingerprints(repo_root)\
    key = _atom_key(persona, topic, role)\
    data["point_hashes"].setdefault(key, \{\})\
    data["situation_hashes"].setdefault(key, \{\})\
    if point_fingerprint and point:\
        data["point_hashes"][key][point_fingerprint(point)] = variant_id\
    if situation_fingerprint and body:\
        data["situation_hashes"][key][situation_fingerprint(body)] = variant_id\
    _save_atom_fingerprints(repo_root, data)\
