{
  "version": 1,
  "updated_at": "2026-03-24",
  "owner": "Pearl_GitHub",
  "purpose": "Machine-readable branch policy scaffold for hourly repo alignment and branch census.",
  "patterns": [
    {
      "pattern": "main",
      "kind": "local",
      "owner": "Pearl_GitHub",
      "disposition": "protected",
      "allowed_actions": ["sync-from-origin-main"],
      "source_doc": "docs/PEARL_GITHUB_ONBOARDING.md",
      "notes": "Never commit directly on local main."
    },
    {
      "pattern": "origin/main",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "protected",
      "allowed_actions": ["compare-against-live", "merge-via-pr-only"],
      "source_doc": "docs/PEARL_GITHUB_ONBOARDING.md",
      "notes": "Canonical remote base for all fresh work."
    },
    {
      "pattern": "agent/*",
      "kind": "local",
      "owner": "Pearl_GitHub",
      "disposition": "active-transient",
      "allowed_actions": ["push", "open-pr", "merge-via-pr", "delete-after-merge"],
      "source_doc": "ps.txt",
      "notes": "Fresh agent branches must start from origin/main and stay bounded."
    },
    {
      "pattern": "origin/agent/*",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "active-transient",
      "allowed_actions": ["review", "merge", "delete-after-merge"],
      "source_doc": "ps.txt",
      "notes": "Remote agent branches should correspond to active or recently merged PR work."
    },
    {
      "pattern": "codex/*",
      "kind": "local",
      "owner": "Pearl_GitHub",
      "disposition": "long-lived-audit",
      "allowed_actions": ["audit", "harvest", "keep-open"],
      "source_doc": "docs/BRANCH_DISPOSITION_2026_03_20.md",
      "notes": "Do not merge blindly; use as audit or harvest sources."
    },
    {
      "pattern": "origin/codex/*",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "audit-required",
      "allowed_actions": ["audit", "harvest", "delete-if-documented"],
      "source_doc": "docs/BRANCH_DISPOSITION_2026_03_20.md",
      "notes": "Remote codex branches require explicit disposition before mutation."
    }
  ],
  "branches": [
    {
      "branch": "origin/codex/runtime-consolidation",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "keep-open",
      "allowed_actions": ["audit", "harvest", "close-after-harvest"],
      "source_doc": "docs/RUNTIME_CONSOLIDATION_HARVEST_PLAN_2026_03_22.md",
      "notes": "Harvest-only branch. Never use as merge vehicle."
    },
    {
      "branch": "codex/runtime-consolidation",
      "kind": "local",
      "owner": "Pearl_GitHub",
      "disposition": "keep-open",
      "allowed_actions": ["audit", "harvest"],
      "source_doc": "docs/RUNTIME_CONSOLIDATION_HARVEST_PLAN_2026_03_22.md",
      "notes": "Local audit copy of harvest-only runtime branch."
    },
    {
      "branch": "origin/codex/ei-v2-hybrid-pr",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "harvest",
      "allowed_actions": ["harvest", "delete-after-harvest"],
      "source_doc": "docs/BRANCH_DISPOSITION_2026_03_20.md",
      "notes": "Focused EI v2 payload; do not merge directly."
    },
    {
      "branch": "origin/codex/governance-100",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "harvest",
      "allowed_actions": ["harvest", "delete-after-harvest"],
      "source_doc": "docs/BRANCH_DISPOSITION_2026_03_20.md",
      "notes": "Harvest specific governance or research files only."
    },
    {
      "branch": "origin/codex/pearl-news-cleanup",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "harvest",
      "allowed_actions": ["harvest", "delete-after-harvest"],
      "source_doc": "docs/BRANCH_DISPOSITION_2026_03_20.md",
      "notes": "Selective Pearl News refactor harvest only."
    },
    {
      "branch": "origin/codex/phoenixcontrol-ui",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "harvest",
      "allowed_actions": ["harvest", "delete-after-harvest"],
      "source_doc": "docs/BRANCH_DISPOSITION_2026_03_20.md",
      "notes": "Focused UI payload; rebase or cherry-pick onto fresh branch."
    },
    {
      "branch": "origin/codex/runtime-governance-core",
      "kind": "remote",
      "owner": "Pearl_GitHub",
      "disposition": "harvest",
      "allowed_actions": ["harvest", "delete-after-harvest"],
      "source_doc": "docs/BRANCH_DISPOSITION_2026_03_20.md",
      "notes": "Split into smaller topic PRs."
    }
  ]
}
