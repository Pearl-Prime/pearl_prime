{
  "name": "Phoenix Omega — cloud-native agent env",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "hostRequirements": {
    "cpus": 2,
    "memory": "8gb",
    "storage": "32gb"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteEnv": {
    "PYTHONPATH": "/workspaces/phoenix_omega_v4.8",
    "PHOENIX_OMEGA_REMOTE": "codespaces"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests/"],
        "files.exclude": {
          "**/.claude/worktrees": true,
          "**/__pycache__": true,
          "**/.pytest_cache": true
        }
      }
    }
  },
  "forwardPorts": [],
  "portsAttributes": {},
  "secrets": {
    "ANTHROPIC_API_KEY": {
      "description": "Only for Pearl_Int validation calls — NOT consumed by repo code (LLM policy enforces ban). Optional."
    },
    "CLOUDFLARE_ACCOUNT_ID": {
      "description": "Cloudflare account id (visible in dash URL)."
    },
    "CLOUDFLARE_API_TOKEN": {
      "description": "Cloudflare API token with R2 read/write scope."
    },
    "GH_TOKEN": {
      "description": "GitHub PAT or fine-grained token. Codespaces auto-provides GITHUB_TOKEN; this is for cross-repo ops."
    },
    "RUNCOMFY_API_TOKEN": {
      "description": "RunComfy API token (optional — Pearl Star renders are local-only by default)."
    },
    "ELEVENLABS_API_KEY": {
      "description": "ElevenLabs TTS key (optional)."
    },
    "DASHSCOPE_API_KEY_SINGAPORE": {
      "description": "Qwen DashScope SINGAPORE region key (Beijing region is wrong)."
    }
  },
  "containerEnv": {
    "PHOENIX_OMEGA_REMOTE": "codespaces"
  },
  "mounts": [],
  "workspaceFolder": "/workspaces/phoenix_omega_v4.8",
  "updateContentCommand": "git fetch --all --prune && bash scripts/git/health_check.sh || true"
}
