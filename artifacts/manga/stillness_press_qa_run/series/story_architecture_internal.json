{
  "schema_version": "1.0.0",
  "artifact_type": "story_architecture_internal",
  "series_id": "sp_qa_iyashikei_001",
  "arc_id": "arc_1",
  "chapters": [
    {
      "chapter_number": 1,
      "chapter_title": "Awakening",
      "mini_arc_stage": "setup",
      "plot_beats": [
        {
          "beat_index": 0,
          "beat_text": "Wide establishing shot of the garden behind the old house. Dawn light, stillness before the day.",
          "is_carrier_beat": true,
          "camera_hint": "wide",
          "mood_hint": "calm"
        },
        {
          "beat_index": 1,
          "beat_text": "Hana appears in silhouette against the garden behind the old house. Their posture tells a story before any word is spoken.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "neutral"
        },
        {
          "beat_index": 2,
          "beat_text": "Close on Hana's hands \u2014 fidgeting, gripping, or still. The body knows what the mind hasn't admitted.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "tense"
        },
        {
          "beat_index": 3,
          "beat_text": "Hana walks through the familiar space. Everything looks the same. Something has shifted.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "neutral"
        },
        {
          "beat_index": 4,
          "beat_text": "A small detail catches Hana's eye \u2014 a crack in the wall, a wilting plant, a clock stopped at the wrong time.",
          "is_carrier_beat": false,
          "camera_hint": "close-up",
          "mood_hint": "neutral"
        },
        {
          "beat_index": 5,
          "beat_text": "the memory of Mother enters the frame without warning. Hana stiffens.",
          "is_carrier_beat": false,
          "camera_hint": "over-shoulder",
          "mood_hint": "tense"
        },
        {
          "beat_index": 6,
          "beat_text": "The first exchange. Words say one thing. Eyes say another. Neither acknowledges the gap.",
          "is_carrier_beat": true,
          "camera_hint": "medium",
          "mood_hint": "tense"
        },
        {
          "beat_index": 7,
          "beat_text": "Hana alone again. They exhale. The room holds the echo.",
          "is_carrier_beat": false,
          "camera_hint": "wide",
          "mood_hint": "calm"
        },
        {
          "beat_index": 8,
          "beat_text": "A memory surfaces \u2014 not as flashback but as body sensation. Hana's shoulders rise.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "dark"
        },
        {
          "beat_index": 9,
          "beat_text": "Night falls over the garden behind the old house. Hana at the window. The reflection stares back.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "dark"
        },
        {
          "beat_index": 10,
          "beat_text": "SILENCE: The world breathes. No dialogue. No action. Just the space between heartbeats.",
          "is_carrier_beat": true,
          "camera_hint": "wide",
          "mood_hint": "calm"
        },
        {
          "beat_index": 11,
          "beat_text": "Hana makes a small choice \u2014 turns left instead of right, picks up a forgotten object, opens a closed door.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "hopeful"
        }
      ],
      "chapter_end_hook": "Turn",
      "turning_point": "ch1_turn",
      "silence_beats_allocated": 1,
      "villain_presence": "absent"
    },
    {
      "chapter_number": 2,
      "chapter_title": "Struggle",
      "mini_arc_stage": "rising",
      "plot_beats": [
        {
          "beat_index": 0,
          "beat_text": "Hana faces the memory of Mother across a charged space. Neither moves first.",
          "is_carrier_beat": false,
          "camera_hint": "wide",
          "mood_hint": "tense"
        },
        {
          "beat_index": 1,
          "beat_text": "Close on Hana's face as realization hits \u2014 the pattern they've been blind to.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "dark"
        },
        {
          "beat_index": 2,
          "beat_text": "Hana tries the old response. It doesn't work anymore. The body rejects the habit.",
          "is_carrier_beat": true,
          "camera_hint": "medium",
          "mood_hint": "tense"
        },
        {
          "beat_index": 3,
          "beat_text": "A confrontation builds. the memory of Mother pushes. Hana almost breaks \u2014 then catches themselves.",
          "is_carrier_beat": false,
          "camera_hint": "over-shoulder",
          "mood_hint": "tense"
        },
        {
          "beat_index": 4,
          "beat_text": "Hana alone, processing. The walls feel closer. Or maybe they always were this close.",
          "is_carrier_beat": false,
          "camera_hint": "wide",
          "mood_hint": "dark"
        },
        {
          "beat_index": 5,
          "beat_text": "An unexpected kindness from a stranger. Hana doesn't know how to receive it.",
          "is_carrier_beat": true,
          "camera_hint": "medium",
          "mood_hint": "calm"
        },
        {
          "beat_index": 6,
          "beat_text": "Hana speaks truth for the first time \u2014 halting, imperfect, real.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "hopeful"
        },
        {
          "beat_index": 7,
          "beat_text": "The cost of the truth lands. Silence follows. Neither person looks away.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "tense"
        },
        {
          "beat_index": 8,
          "beat_text": "Hana walks a new path. Each step deliberate. The ground feels different.",
          "is_carrier_beat": false,
          "camera_hint": "wide",
          "mood_hint": "neutral"
        },
        {
          "beat_index": 9,
          "beat_text": "SILENCE: A breath held and released. The world continues. Something has loosened.",
          "is_carrier_beat": true,
          "camera_hint": "wide",
          "mood_hint": "calm"
        },
        {
          "beat_index": 10,
          "beat_text": "the memory of Mother shows a crack in their armor. For one panel, the shadow looks human.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "neutral"
        },
        {
          "beat_index": 11,
          "beat_text": "Hana returns to a familiar place but sees it differently. The change is internal.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "hopeful"
        }
      ],
      "chapter_end_hook": "Escalation",
      "turning_point": "ch2_turn",
      "silence_beats_allocated": 1,
      "villain_presence": "present"
    },
    {
      "chapter_number": 3,
      "chapter_title": "Resolution",
      "mini_arc_stage": "climax",
      "plot_beats": [
        {
          "beat_index": 0,
          "beat_text": "Hana and the memory of Mother face each other for the final time. This isn't about winning.",
          "is_carrier_beat": false,
          "camera_hint": "wide",
          "mood_hint": "tense"
        },
        {
          "beat_index": 1,
          "beat_text": "Everything Hana has learned crystallizes in one moment. The body moves before the mind.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "tense"
        },
        {
          "beat_index": 2,
          "beat_text": "Hana chooses the harder path \u2014 not the dramatic one, but the honest one.",
          "is_carrier_beat": true,
          "camera_hint": "medium",
          "mood_hint": "hopeful"
        },
        {
          "beat_index": 3,
          "beat_text": "the memory of Mother falters. Not defeated \u2014 seen. The shadow recognized is no longer a shadow.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "neutral"
        },
        {
          "beat_index": 4,
          "beat_text": "The world holds still. What needed to happen has happened. What needed to break has broken.",
          "is_carrier_beat": false,
          "camera_hint": "wide",
          "mood_hint": "calm"
        },
        {
          "beat_index": 5,
          "beat_text": "SILENCE: The deepest pause. Three panels of nothing but breath and light.",
          "is_carrier_beat": true,
          "camera_hint": "wide",
          "mood_hint": "calm"
        },
        {
          "beat_index": 6,
          "beat_text": "Hana stands in the aftermath. Changed not by victory but by surrender.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "hopeful"
        },
        {
          "beat_index": 7,
          "beat_text": "A hand extended \u2014 to the memory of Mother, to self, to the reader. Integration, not triumph.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "hopeful"
        },
        {
          "beat_index": 8,
          "beat_text": "Hana speaks the last words of the arc. Quiet. Unforced. True.",
          "is_carrier_beat": false,
          "camera_hint": "medium",
          "mood_hint": "calm"
        },
        {
          "beat_index": 9,
          "beat_text": "the garden behind the old house at peace. The light has changed. Dawn or dusk \u2014 it doesn't matter. What matters is the stillness.",
          "is_carrier_beat": false,
          "camera_hint": "wide",
          "mood_hint": "calm"
        },
        {
          "beat_index": 10,
          "beat_text": "Final panel: Hana's eyes. Not resolved. Not healed. Awake.",
          "is_carrier_beat": true,
          "camera_hint": "close-up",
          "mood_hint": "hopeful"
        },
        {
          "beat_index": 11,
          "beat_text": "SILENCE: The story ends where the reader begins. No summary. No lesson. Just the echo.",
          "is_carrier_beat": true,
          "camera_hint": "wide",
          "mood_hint": "calm"
        }
      ],
      "chapter_end_hook": "Echo",
      "turning_point": null,
      "silence_beats_allocated": 2,
      "villain_presence": "present"
    }
  ],
