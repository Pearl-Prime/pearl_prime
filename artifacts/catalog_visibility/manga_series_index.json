    {
      "brand_id": "stillness_press",
      "catalog_id": "en_us_core",
      "locale": "en_US",
      "series_id": "anxiety_overwhelm_vol1",
      "series_title": "After the Noise",
      "series_logline": "Read this when the world is still loud and your body hasn't caught up yet.",
      "series_description": "This series is for readers who have been told their anxiety is \"not that bad.\"\nThe visual grammar does the work: long silent sequences + sparse dialogue +\nrestrained line work = the reader feels their own nervous system slow down.\nDo not add dramatic chapter hooks. The mood_based engine is intentional.\nThe emotional engine (cozy_restoration) means readers finish each chapter\nfeeling safer, not more activated.",
      "market_demo": "josei",
      "genre_family": "healing",
      "subgenre": "slice_of_life_anxiety_recovery",
      "emotional_engine": "cozy_restoration",
      "serialization_engine": "mood_based",
      "visual_grammar": "iyashikei_minimalism",
      "reader_promise": "You will feel like someone finally understands what exhaustion really is.",
      "positioning": "For readers of Mushishi who also want a series that understands what exhaustion actually feels like.",
      "audience": "She is 29-38, works in a job that requires her to be on — meetings, emails,\ndecisions — from 8am to whenever the inbox empties. At 11pm she is lying in\nbed with her phone, not sleeping, not quite awake, not knowing what she needs.\nShe has been told her anxiety isn't that serious, and she has believed it,\nand she is tired of believing it.",
      "comp_titles": [
        "Mushishi (Yuki Urushibara)",
        "My Lesbian Experience With Loneliness (Nagata Kabi)",
        "A Silent Voice (Yoshitoki Oima)",
        "Burnout: The Secret to Unlocking the Stress Cycle (Emily Nagoski, Amelia Nagoski)"
      ],
      "marketing_angle": "Unlike most healing content that explains exhaustion back to you, this series\ntrusts the reader: long silent sequences, restrained dialogue, and watercolor\nspace do the work — each chapter finishes and you feel lighter without\nknowing why. The iyashikei visual grammar IS the restoration.",
      "hook_lines": [
        "For when your body quit before your calendar did.",
        "Quiet that actually stays quiet.",
        "The manga that understands what fine doesn't feel like."
      ],
      "launch_priority": "P0",
      "status": "draft",
      "main_character_name": "Nao",
      "main_character_role": "overextended project coordinator",
      "main_character_image_path": null,
