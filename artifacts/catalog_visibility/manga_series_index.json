    {
      "brand_id": "cognitive_clarity",
      "catalog_id": "en_us_core",
      "locale": "en_US",
      "series_id": "battle_shonen_template_001",
      "series_title": "Born to Rise",
      "series_logline": "For the reader who needs to watch someone refuse to stay down, chapter after chapter.",
      "series_description": "Standard tournament arc structure. 52 planned chapters, 4 arcs.\nChapter_end_hooks must be new_rival or revelation family (no soft close on weekly serialization).\nThe aspiration engine requires the protagonist to VISIBLY improve — power levels\nmust feel earned. Avoid power-up-via-emotion without shown training basis (Naruto\nlate-arc failure mode).\nObserver dialogue (\"Impossible...!\") is load-bearing genre content, not noise.",
      "market_demo": "shonen",
      "genre_family": "battle",
      "subgenre": "tournament_arc_martial_arts",
      "emotional_engine": "aspiration",
      "serialization_engine": "tournament_ladder",
      "visual_grammar": "kinetic_shonen",
      "reader_promise": "You will feel the specific electricity of someone becoming who they were always meant to be.",
      "positioning": "For readers of Haikyu!! who also want a series that earns every power-up with visible sweat and consequence.",
      "audience": "He is 13-22, has tried something and failed, or is afraid to try.\nAt 11pm he is watching tournament recap videos or thinking about the team\nhe almost made, the match he almost won. He needs to see someone who loses\nbadly and gets up anyway.",
      "comp_titles": [
        "Haikyu!! (Haruichi Furudate)",
        "My Hero Academia (Kohei Horikoshi)",
        "Demon Slayer (Koyoharu Gotouge)",
        "Grit: The Power of Passion and Perseverance (Angela Duckworth)"
      ],
      "marketing_angle": "A tournament arc series that trusts the aspiration engine fully: every\nsetback is earned, every power-up has visible cost, and the cognitive_clarity\nhigh-contrast visual grammar makes the physics of effort look as clean and\nlegible as the stakes. No shortcuts, no plot armor.",
      "hook_lines": [
        "Watch someone get back up. Every chapter.",
        "You don't need to be ready. You need to start.",
        "The tournament bracket is the story. Pick a side."
      ],
      "launch_priority": "P1",
      "status": "draft",
      "main_character_name": "Kai",
      "main_character_role": "first-generation martial arts student",
      "main_character_image_path": null,
      "plan_source_path": "/Users/ahjan/phoenix_omega/.claude/worktrees/elated-bell-a3e9a4/config/source_of_truth/manga_profiles/examples/example_battle_shonen.yaml"
