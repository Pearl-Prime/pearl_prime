    {
      "brand_id": "stillness_press",
      "catalog_id": "en_us_core",
      "locale": "en_US",
      "series_id": "josei_workplace_romance_001",
      "series_title": "What I Almost Said",
      "series_logline": "For the reader who has spent three months noticing someone who hasn't noticed back.",
      "series_description": "This profile demonstrates the core distinction between shojo and josei grammar:\n1. No decorative visual effects (sparkle, flower, chibi deformation)\n2. Emotional precision over emotional performance\n3. Restraint-over-exposition: the reader fills the silence with their own longing\n4. Realistic workplace detail matters — the reader LIVES this\n5. Chapter hooks are almost_confession family, not new_rival or revelation\n   (no manufactured drama; the emotional territory IS the drama)\n\nThe MDLG-11 (restraint_over_exposition) gate should treat this series as\nthe canonical test case for josei grammar compliance.\n\nDo not let the Chapter Writer add exclamation marks to internal monologue.\nJosei characters think in period-ending sentences.",
      "market_demo": "josei",
      "genre_family": "workplace",
      "subgenre": "slow_burn_office_romance_burnout",
      "emotional_engine": "longing",
      "serialization_engine": "relationship_escalation",
      "visual_grammar": "grounded_josei_realism",
      "reader_promise": "You will feel the exact particular ache of wanting someone you cannot have at work.",
      "positioning": "For readers of Honey and Clover who also want the ache to happen inside a recognizable workplace, not around one.",
      "audience": "She is 27-40, works in a real job — creative agency, corporate office,\nsomewhere with open-plan floors and too many meetings. At 11pm she is\nreplaying a moment from today: a glance held two seconds longer than\nnecessary, an email she almost sent. She does not expect the feeling\nto go anywhere. That is the point.",
      "comp_titles": [
        "Honey and Clover (Chica Umino)",
        "Nana (Ai Yazawa)",
        "Chihayafuru (Yuki Suetsugu)",
        "Why Love Hurts (Eva Illouz)"
      ],
      "marketing_angle": "The workplace romance that refuses to manufacture drama: no rival,\nno confession scene, just the specific weight of sitting three desks\naway from someone you want. Grounded_josei_realism means it looks\nlike your life, not a fantasy version of it.",
      "hook_lines": [
        "For everyone who has an email they never sent.",
        "Three desks away and ten thousand miles gone.",
        "The ache without the catharsis. That's the point."
      ],
      "launch_priority": "P1",
      "status": "draft",
      "main_character_name": "Akari",
      "main_character_role": "overworked junior art director",
      "main_character_image_path": null,
      "plan_source_path": "/Users/ahjan/phoenix_omega/.claude/worktrees/elated-bell-a3e9a4/config/source_of_truth/manga_profiles/examples/example_josei_workplace.yaml"
