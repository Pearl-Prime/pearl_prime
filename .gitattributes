# Git LFS tracking — binary assets that bloat git history
# Authority: docs/GIT_LFS_MIGRATION_PLAN.md
# Date: 2026-04-10

# Audio
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.m4a filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.flac filter=lfs diff=lfs merge=lfs -text

# Video
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text

# Images (large binaries)
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# Cloudflare Pages wizard assets — must be regular git blobs (CF Pages does not pull LFS)
brand-wizard-app/public/onboarding/proof/wizard/*.png -filter -diff -merge text
brand-wizard-app/public/onboarding/proof/wizard/*.jpg -filter -diff -merge text
brand-wizard-app/public/onboarding/proof/wizard/*.mp3 -filter -diff -merge text

# Documents (binary formats)
*.pdf filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.xls filter=lfs diff=lfs merge=lfs -text

# Archives & project files
*.zip filter=lfs diff=lfs merge=lfs -text
*.lpf filter=lfs diff=lfs merge=lfs -text

# OS images & packages (guard against pearl_star-type incidents)
*.iso filter=lfs diff=lfs merge=lfs -text
*.deb filter=lfs diff=lfs merge=lfs -text

# ML model weights (guard against accidental commits)
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text

# Cloudflare Pages wizard assets — must be regular git blobs (CF Pages does not pull LFS)
# IMPORTANT: use -text to prevent CRLF normalization from corrupting binary PNG/MP3 data
brand-wizard-app/public/onboarding/proof/wizard/*.png -filter -diff -merge -text
brand-wizard-app/public/onboarding/proof/wizard/*.jpg -filter -diff -merge -text
brand-wizard-app/public/onboarding/proof/wizard/*.mp3 -filter -diff -merge -text
