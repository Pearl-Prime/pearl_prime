{
    "_meta": {
        "name": "Phoenix Omega — FLUX img2img Manga Teacher Character",
        "description": "Standard img2img style transfer: encode reference photo to latent, denoise at 0.78 toward manga style prompt. Preserves face structure through latent space. Uses flux1-dev with dpmpp_2m/karras; schnell (4-step distilled) is incompatible with steps>=8 and cfg>1 and silently degraded outputs prior to v1.1.0.",
        "version": "1.1.0",
        "author": "Phoenix Omega"
    },
    "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
            "ckpt_name": "flux1-dev-fp8.safetensors"
        }
    },
    "2": {
        "class_type": "LoadImage",
        "inputs": {
            "image": "{{input_image}}"
        }
    },
    "3": {
        "class_type": "ImageScale",
        "inputs": {
            "upscale_method": "lanczos",
            "width": 768,
            "height": 1024,
            "crop": "center",
            "image": ["2", 0]
        }
    },
    "4": {
        "class_type": "VAEEncode",
        "inputs": {
            "pixels": ["3", 0],
            "vae": ["1", 2]
        }
    },
    "5": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "{{positive_prompt}}",
            "clip": ["1", 1]
        }
    },
    "6": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "{{negative_prompt}}",
            "clip": ["1", 1]
        }
    },
    "7": {
        "class_type": "KSampler",
        "inputs": {
            "seed": 42,
            "steps": 28,
            "cfg": 3.5,
            "sampler_name": "dpmpp_2m",
            "scheduler": "karras",
            "denoise": 0.78,
            "model": ["1", 0],
            "positive": ["5", 0],
            "negative": ["6", 0],
            "latent_image": ["4", 0]
        }
    },
    "8": {
        "class_type": "VAEDecode",
        "inputs": {
            "samples": ["7", 0],
            "vae": ["1", 2]
        }
    },
    "9": {
        "class_type": "SaveImage",
        "inputs": {
            "filename_prefix": "manga_teacher_img2img",
            "images": ["8", 0]
        }
    }
}
