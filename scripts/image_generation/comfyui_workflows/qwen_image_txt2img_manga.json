{
    "_meta": {
        "name": "Phoenix Omega — Qwen-Image txt2img (manga panel; CJK + character work)",
        "description": "Qwen-Image base (Apache 2.0; weakest 'average face' attractor per artifacts/research/average_face_problem_eval_2026-05-02.md). Primary base for character-distinctness work AND speech-bubble text rendering on JP/CN locales (Qwen2.5-VL text encoder is bidirectional T5-family; responds to natural-language prose, not danbooru tags). Reference image input via PuLID slot if engine_router has it; else pure-text mode. 1080x1920 webtoon vertical default.",
        "version": "1.0.0",
        "phase": "V2-B-base-Qwen",
        "license_notes": "Qwen-Image Apache 2.0; Qwen2.5-VL Apache 2.0",
        "reference_image_path": "Optional; PulidFluxFaceNetLoader works on Qwen via the same node pack; leave empty for pure-text mode"
    },
    "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {"ckpt_name": "qwen_image_2.0.safetensors"}
    },
    "2": {
        "class_type": "CLIPTextEncode",
        "inputs": {"text": "{{positive_prompt}}", "clip": ["1", 1]}
    },
    "3": {
        "class_type": "CLIPTextEncode",
        "inputs": {"text": "{{negative_prompt}}", "clip": ["1", 1]}
    },
    "4": {
        "class_type": "EmptyLatentImage",
        "inputs": {"width": 1080, "height": 1920, "batch_size": 1}
    },
    "10": {
        "class_type": "LoadImage",
        "inputs": {"image": "{{reference_image}}"}
    },
    "11": {
        "class_type": "PulidFluxFaceNetLoader",
        "inputs": {}
    },
    "12": {
        "class_type": "ApplyPulidFlux",
        "inputs": {
            "model": ["1", 0],
            "pulid_flux": ["11", 0],
            "reference_image": ["10", 0],
            "weight": 0.83,
            "start_at": 0.0,
            "end_at": 1.0,
            "method": "fidelity"
        }
    },
    "5": {
        "class_type": "KSampler",
        "inputs": {
            "seed": 42,
            "steps": 24,
            "cfg": 4.0,
            "sampler_name": "euler",
            "scheduler": "simple",
            "denoise": 1.0,
            "model": ["12", 0],
            "positive": ["2", 0],
            "negative": ["3", 0],
            "latent_image": ["4", 0]
        }
    },
    "6": {
        "class_type": "VAEDecode",
        "inputs": {"samples": ["5", 0], "vae": ["1", 2]}
    },
    "7": {
        "class_type": "SaveImage",
        "inputs": {"filename_prefix": "manga_panel_qwen", "images": ["6", 0]}
    }
}
