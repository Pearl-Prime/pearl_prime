{
    "_meta": {
        "name": "Phoenix Omega — Qwen-Image txt2img (manga panel; CJK + character work)",
        "description": "Qwen-Image split-files loader (UNETLoader + CLIPLoader + VAELoader) with optional PuLID face-lock. Shard-complete Pearl Star installs use split loaders per pearl_star_node_inventory.md §Qwen; unified checkpoint path is legacy.",
        "version": "1.1.0",
        "phase": "V2-B-base-Qwen",
        "license_notes": "Qwen-Image Apache 2.0; Qwen2.5-VL Apache 2.0"
    },
    "1": {
        "class_type": "UNETLoader",
        "inputs": {
            "unet_name": "qwen_image_fp8_e4m3fn.safetensors",
            "weight_dtype": "fp8_e4m3fn"
        }
    },
    "8": {
        "class_type": "CLIPLoader",
        "inputs": {
            "clip_name": "qwen_2.5_vl_7b_fp8_scaled.safetensors",
            "type": "qwen_image"
        }
    },
    "9": {
        "class_type": "VAELoader",
        "inputs": {
            "vae_name": "split_files/vae/qwen_image_vae.safetensors"
        }
    },
    "2": {
        "class_type": "CLIPTextEncode",
        "inputs": {"text": "{{positive_prompt}}", "clip": ["8", 0]}
    },
    "3": {
        "class_type": "CLIPTextEncode",
        "inputs": {"text": "{{negative_prompt}}, text, words, letters, captions, watermark, signature, signs, writing, typography, text characters, font, lettering, logos, subtitles, calligraphy, chinese characters, japanese characters, kanji, hiragana, katakana, hangul", "clip": ["8", 0]}
    },
    "4": {
        "class_type": "EmptyLatentImage",
        "inputs": {"width": 1080, "height": 1920, "batch_size": 1}
    },
    "10": {
        "class_type": "LoadImage",
        "inputs": {"image": "{{reference_image}}"}
    },
    "11": {
        "class_type": "PulidFluxFaceNetLoader",
        "inputs": {}
    },
    "12": {
        "class_type": "ApplyPulidFlux",
        "inputs": {
            "model": ["1", 0],
            "pulid_flux": ["11", 0],
            "reference_image": ["10", 0],
            "weight": 0.83,
            "start_at": 0.0,
            "end_at": 1.0,
            "method": "fidelity"
        }
    },
    "5": {
        "class_type": "KSampler",
        "inputs": {
            "seed": 42,
            "steps": 24,
            "cfg": 4.0,
            "sampler_name": "euler",
            "scheduler": "simple",
            "denoise": 1.0,
            "model": ["12", 0],
            "positive": ["2", 0],
            "negative": ["3", 0],
            "latent_image": ["4", 0]
        }
    },
    "6": {
        "class_type": "VAEDecode",
        "inputs": {"samples": ["5", 0], "vae": ["9", 0]}
    },
    "7": {
        "class_type": "SaveImage",
        "inputs": {"filename_prefix": "manga_panel_qwen", "images": ["6", 0]}
    }
}
