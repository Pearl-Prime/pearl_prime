{
    "_meta": {
        "name": "Phoenix Omega — FLUX IP-Adapter Manga Teacher Character",
        "description": "Face-preserving manga style transfer using IP-Adapter FaceID + FLUX. Takes reference photo as input, outputs manga-style character portrait. Uses flux1-dev with dpmpp_2m/karras; schnell (4-step distilled) is incompatible with steps>=8 and cfg>1 and silently degraded outputs prior to v1.1.0.",
        "version": "1.1.0",
        "author": "Phoenix Omega"
    },
    "1": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
            "ckpt_name": "flux1-dev-fp8.safetensors"
        }
    },
    "2": {
        "class_type": "IPAdapterUnifiedLoader",
        "inputs": {
            "preset": "FACEID",
            "model": ["1", 0]
        }
    },
    "3": {
        "class_type": "LoadImage",
        "inputs": {
            "image": "{{input_image}}"
        }
    },
    "4": {
        "class_type": "IPAdapterAdvanced",
        "inputs": {
            "weight": 0.85,
            "weight_type": "style transfer",
            "combine_embeds": "average",
            "start_at": 0.0,
            "end_at": 1.0,
            "model": ["2", 0],
            "ipadapter": ["2", 1],
            "image": ["3", 0]
        }
    },
    "5": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "{{positive_prompt}}",
            "clip": ["1", 1]
        }
    },
    "6": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "{{negative_prompt}}",
            "clip": ["1", 1]
        }
    },
    "7": {
        "class_type": "EmptyLatentImage",
        "inputs": {
            "width": 768,
            "height": 1024,
            "batch_size": 1
        }
    },
    "8": {
        "class_type": "KSampler",
        "inputs": {
            "seed": 42,
            "steps": 28,
            "cfg": 3.5,
            "sampler_name": "dpmpp_2m",
            "scheduler": "karras",
            "denoise": 1.0,
            "model": ["4", 0],
            "positive": ["5", 0],
            "negative": ["6", 0],
            "latent_image": ["7", 0]
        }
    },
    "9": {
        "class_type": "VAEDecode",
        "inputs": {
            "samples": ["8", 0],
            "vae": ["1", 2]
        }
    },
    "10": {
        "class_type": "SaveImage",
        "inputs": {
            "filename_prefix": "manga_teacher_ipadapter",
            "images": ["9", 0]
        }
    }
}
