# Credentials Manifest — Template for bulk platform credential setup.
#
# Copy this file to credentials_manifest.yaml and fill in your values.
# This file is LOCAL-ONLY and must NEVER be committed to git.
# Add credentials_manifest.yaml to .gitignore.
#
# Usage:
#   1. Fill in the shared OAuth client credentials per platform
#   2. List all brands with their suffixes and account emails
#   3. Run the OAuth scripts in batch mode:
#      python scripts/video/credential_setup/youtube_oauth.py --manifest credentials_manifest.yaml --output .credentials.env
#      python scripts/video/credential_setup/tiktok_oauth.py --manifest credentials_manifest.yaml --output .credentials.env
#      python scripts/video/credential_setup/instagram_oauth.py --manifest credentials_manifest.yaml --output .credentials.env
#   4. Wire all credentials to GitHub Secrets:
#      python scripts/video/credential_setup/wire_secrets.py --env-file .credentials.env
#   5. Delete .credentials.env after wiring

# ── YouTube (Google Cloud Console) ──────────────────────────────────────────
youtube:
  # Shared OAuth2 client credentials (one GCP project for all brands)
  client_id: ""          # From Google Cloud Console → APIs → Credentials → OAuth 2.0 Client
  client_secret: ""      # Same location — copy the client secret

# ── TikTok (TikTok Developer Portal) ───────────────────────────────────────
tiktok:
  # Shared app credentials (one TikTok developer app for all brands)
  client_key: ""         # From TikTok Developer Portal → Manage apps → App Key
  client_secret: ""      # Same location — App Secret

# ── Instagram Reels (Meta Developer Portal) ────────────────────────────────
instagram:
  # Shared Meta app credentials (one Meta app for all brands)
  app_id: ""             # From Meta Developer Portal → My Apps → App ID
  app_secret: ""         # Same location → Settings → Basic → App Secret

# ── Brands ──────────────────────────────────────────────────────────────────
# Each brand gets its own set of platform credentials.
# The suffix is appended to secret names (e.g., YT_REFRESH_TOKEN_SP).
# The email is the Google/platform account that owns the brand's channels.
brands:
  - suffix: "_SP"
    name: "Stillness Press"
    youtube_email: "hello@48social.com"
    tiktok_username: ""    # TikTok account username for this brand
    instagram_page: ""     # Facebook Page name linked to IG Business account
    platforms:
      youtube: true
      youtube_shorts: true
      tiktok: true
      instagram_reels: true
      bilibili: false
      douyin: false

  - suffix: "_CC"
    name: "Cognitive Clarity"
    youtube_email: "gmalone@oneteamtech.com"
    tiktok_username: ""
    instagram_page: ""
    platforms:
      youtube: true
      youtube_shorts: true
      tiktok: true
      instagram_reels: true
      bilibili: false
      douyin: false

  # ── Add more brands below ──────────────────────────────────────────────
  # - suffix: "_ND"
  #   name: "NorCal Dharma"
  #   youtube_email: ""
  #   tiktok_username: ""
  #   instagram_page: ""
  #   platforms:
  #     youtube: true
  #     tiktok: true
  #     instagram_reels: true
