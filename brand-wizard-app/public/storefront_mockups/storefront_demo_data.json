  "sample_reviews_en_US": [
    {
      "review_id": "rev_01",
      "sku_id": "book_en_US_stillness_press_anxiety_corporate_managers_ahjan",
      "reviewer_name": "Mira K.",
      "stars": 5,
      "body": "I'm a director at a mid-size firm. I picked this up after a particularly brutal Q4 — my doctor said it was anxiety, my therapist said it was burnout, and my body was telling me both. The 'Sunday dread' chapter alone was worth the cost. Practical. Not preachy. Doesn't pretend to fix you.",
      "verified": true,
      "helpful_count": 38,
      "locale": "en-US",
      "created_at": "2026-05-12"
    },
    {
      "review_id": "rev_02",
      "sku_id": "book_en_US_stillness_press_anxiety_corporate_managers_ahjan",
      "reviewer_name": "James T.",
      "stars": 4,
      "body": "Solid. Wanted more on the workplace-meeting practices specifically — the existing chapter is good but I'd happily read a whole volume on just that. Otherwise this is the first anxiety book that didn't make me feel like I needed to become a different person.",
      "verified": true,
      "helpful_count": 12,
      "locale": "en-US",
      "created_at": "2026-04-28"
    },
    {
      "review_id": "rev_03",
      "sku_id": "book_en_US_stillness_press_anxiety_corporate_managers_ahjan",
      "reviewer_name": "Reader",
      "stars": 5,
      "body": "Bought this for my sister, ended up reading it myself first. The tone is exactly right — no performative softness, no toxic positivity. Felt like someone finally talking to me like an adult who happens to be struggling.",
      "verified": false,
      "helpful_count": 7,
      "locale": "en-US",
      "created_at": "2026-05-02"
    }
  ],

