{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memorable_line_registry_snapshot_v1.schema.json",
  "title": "MemorableLineRegistrySnapshotV1",
  "description": "Compacted state of the cross-catalog memorable line registry.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "lines"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "generated_at": { "type": "string", "description": "ISO-8601 timestamp" },
    "lines": {
      "type": "array",
      "items": { "$ref": "#/$defs/RegistryLine" }
    }
  },
  "$defs": {
    "RegistryLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line_hash", "normalized_text", "occurrence_count", "books"],
      "properties": {
        "line_hash": { "type": "string", "description": "sha256(normalized_text)" },
        "normalized_text": { "type": "string" },
        "first_seen_book_id": { "type": "string" },
        "occurrence_count": { "type": "integer", "minimum": 0 },
        "books": { "type": "array", "items": { "type": "string" } },
        "brands": { "type": "array", "items": { "type": "string" } },
        "strength_max": { "type": "string", "enum": ["ok", "good", "great"] },
        "last_seen_at": { "type": "string", "description": "ISO-8601" }
      }
    }
  }
}
