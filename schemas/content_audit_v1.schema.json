{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContentAudit",
  "description": "Teacher Authoring Layer — content audit (doctrine/content_audit.yaml)",
  "type": "object",
  "required": ["schema_version", "teacher_id", "files"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string" },
    "teacher_id": { "type": "string" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["filename", "usability", "atom_types", "mta_coverage", "notes"],
        "properties": {
          "filename": { "type": "string" },
          "usability": { "type": "string", "enum": ["high", "medium", "low"] },
          "atom_types": { "type": "array", "items": { "type": "string" } },
          "mta_coverage": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" },
          "extraction_warnings": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "unusable_content": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
