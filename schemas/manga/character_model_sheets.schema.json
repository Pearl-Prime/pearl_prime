{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/character_model_sheets.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "characters"],
      "properties": {
        "artifact_type": { "const": "character_model_sheets" },
        "characters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["character_id"],
            "properties": { "character_id": { "type": "string", "minLength": 1 } }
          }
        }
      }
    }
  ]
}
