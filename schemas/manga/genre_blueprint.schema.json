{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/genre_blueprint.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "genre_id"],
      "properties": {
        "artifact_type": { "const": "genre_blueprint" },
        "genre_id": { "type": "string", "minLength": 1 },
        "arc_structure": { "type": "object" }
      }
    }
  ]
}
