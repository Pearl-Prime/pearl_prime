{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/revision_queue.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "chapter_clearance", "issues"],
      "properties": {
        "artifact_type": { "const": "revision_queue" },
        "chapter_clearance": { "type": "string", "enum": ["pass", "hold"] },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["issue_code", "gate_id", "severity", "stage_owner"],
            "properties": {
              "issue_code": { "type": "string", "minLength": 1 },
              "gate_id": { "type": "string", "minLength": 1 },
              "severity": { "type": "string", "enum": ["BLOCKER", "MAJOR", "MINOR"] },
              "stage_owner": { "type": "string", "minLength": 1 },
              "suggested_action": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
