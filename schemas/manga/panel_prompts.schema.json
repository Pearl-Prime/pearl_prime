{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/panel_prompts.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "panels"],
      "properties": {
        "artifact_type": { "const": "panel_prompts" },
        "series_id": { "type": "string" },
        "chapter_id": { "type": "string" },
        "config_hash": { "type": "string" },
        "render_routing": {
          "type": "object",
          "description": "LANE D chapter-level engine-routing provenance (engine_router.select_engine). Records the commercial-clean base-model / workflow / sampler selection + reasoning for this chapter's panels.",
          "properties": {
            "engine": { "type": ["string", "null"] },
            "workflow_path": { "type": ["string", "null"] },
            "sampler": { "type": ["object", "null"] },
            "reference_enabled": { "type": ["boolean", "null"] },
            "reasoning": { "type": ["string", "null"] },
            "fallback_used": { "type": ["boolean", "null"] },
            "fallback_reason": { "type": ["string", "null"] },
            "individuation_engaged": { "type": ["boolean", "null"] }
          }
        },
        "panels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["panel_id", "prompt"],
            "properties": {
              "panel_id": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string" },
              "negative_prompt": { "type": "string" },
              "composition_notes": { "type": "object" },
              "prompt_token_count": { "type": "integer", "minimum": 0 },
              "negative_token_count": { "type": "integer", "minimum": 0 },
              "continuity_tags": { "type": "array", "items": { "type": "string" } },
              "silence_compliance": { "type": "boolean" },
              "atom_type": { "type": "string" },
              "engine_type": { "type": "string" },
              "style_id": { "type": "string" },
              "teacher_id": { "type": "string" },
              "panel_function": { "type": "string" },
              "render_routing": {
                "type": "object",
                "description": "LANE D per-panel engine-routing decision (engine_router.select_engine) recorded so the image backend / queue dispatcher renders per-panel without re-deriving it. Commercial-clean stack per artifacts/research/license_risk_register_2026-04-29.md.",
                "properties": {
                  "engine": {
                    "type": ["string", "null"],
                    "description": "Base model id: qwen_image | animagine_xl_4_0 | flux_schnell"
                  },
                  "workflow_path": { "type": ["string", "null"] },
                  "sampler": { "type": ["object", "null"] },
                  "reference_enabled": { "type": ["boolean", "null"] },
                  "individuation_engaged": {
                    "type": ["boolean", "null"],
                    "description": "True iff axis-specific character_design tokens were folded into this panel's prompt."
                  }
                }
              },
              "sdf_conditioning": {
                "type": "object",
                "description": "Layer 2.5 geometric prior (§6.7 MANGA_MODE_SYSTEM_SPEC); Comfy/ControlNet consumes maps when trained.",
                "properties": {
                  "layer": { "type": "string" },
                  "map_kind": {
                    "type": "string",
                    "enum": ["disabled", "depth", "contour", "replay_fixture"]
                  },
                  "pose_mod": { "type": "string" },
                  "controlnet_strength": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "model_ref": {
                    "type": "string",
                    "description": "Path or URI to trained neural SDF weights when available"
                  },
                  "conditioning_map_path": {
                    "type": "string",
                    "description": "Optional projected depth/contour image for ControlNet"
                  },
                  "spec_ref": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  ]
}
