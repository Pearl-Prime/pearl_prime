{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/panel_prompts.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "panels"],
      "properties": {
        "artifact_type": { "const": "panel_prompts" },
        "series_id": { "type": "string" },
        "chapter_id": { "type": "string" },
        "config_hash": { "type": "string" },
        "panels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["panel_id", "prompt"],
            "properties": {
              "panel_id": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string" },
              "negative_prompt": { "type": "string" },
              "composition_notes": { "type": "object" },
              "prompt_token_count": { "type": "integer", "minimum": 0 },
              "negative_token_count": { "type": "integer", "minimum": 0 },
              "continuity_tags": { "type": "array", "items": { "type": "string" } },
              "silence_compliance": { "type": "boolean" },
              "atom_type": { "type": "string" },
              "engine_type": { "type": "string" },
              "style_id": { "type": "string" },
              "teacher_id": { "type": "string" },
              "panel_function": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
