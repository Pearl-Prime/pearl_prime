{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/lettering_spec.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "lettering_panels"],
      "properties": {
        "artifact_type": { "const": "lettering_spec" },
        "lettering_panels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["panel_id"],
            "properties": {
              "panel_id": { "type": "string", "minLength": 1 },
              "silence_confirmed": { "type": "boolean" }
            }
          }
        }
      }
    }
  ]
}
