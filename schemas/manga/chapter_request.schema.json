{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/chapter_request.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "series_id", "chapter_id"],
      "properties": {
        "artifact_type": { "const": "chapter_request" },
        "series_id": { "type": "string", "minLength": 1 },
        "chapter_id": { "type": "string", "minLength": 1 },
        "arc_id": { "type": "string" }
      }
    }
  ]
}
