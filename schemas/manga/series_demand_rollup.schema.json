{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/series_demand_rollup.schema.json",
  "title": "Manga Series Image-Bank Demand Rollup",
  "description": "Series-level image-bank demand analysis derived from a series_master_plan (schemas/manga/series_master_plan.schema.json) + the series' authored bank contracts (scene/object/pose inventories) + existing storyboards/gap files + on-disk image_bank coverage. ANALYSIS artifact only — it plans WHAT to build for the bank; it renders nothing. Authority: docs/specs/MANGA_LAYER_RENDER_CONTRACT_SPEC.md (L0-L4 taxonomy), docs/specs/MANGA_V5_LAYERED_ARCHITECTURE.md (PuLID-first, LoRA flagship-only). Generated by scripts/manga/generate_bank_contracts_from_script.py --series-rollup.",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "series_id",
    "brand_id",
    "locale",
    "episode_horizon",
    "detailed_window_end",
    "generated_from",
    "demand",
    "coverage_summary",
    "identity_lock_plan",
    "render_queue_estimate",
    "acceptance_layer"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "artifact_type": { "type": "string", "const": "series_demand_rollup" },
    "schema_authority": {
      "type": "string",
      "const": "schemas/manga/series_demand_rollup.schema.json"
    },
    "series_id": { "type": "string", "minLength": 1 },
    "brand_id": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "minLength": 1 },
    "episode_horizon": { "type": "integer", "minimum": 1 },
    "episodes_planned": { "type": "integer", "minimum": 0 },
    "detailed_window_end": { "type": "integer", "minimum": 0 },
    "generated_from": {
      "type": "object",
      "required": ["master_plan"],
      "properties": {
        "master_plan": { "type": "string", "minLength": 1 },
        "bank_contracts": { "type": "array", "items": { "type": "string" } },
        "gap_files": { "type": "array", "items": { "type": "string" } },
        "image_bank_root": { "type": "string" },
        "storyboards_scanned": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "provenance": { "type": "object", "additionalProperties": true },
    "demand": {
      "type": "object",
      "required": ["l0_backdrops", "l2_character_poses", "l3_objects"],
      "properties": {
        "l0_backdrops": {
          "type": "array",
          "items": { "$ref": "#/$defs/l0_row" }
        },
        "l2_character_poses": {
          "type": "array",
          "items": { "$ref": "#/$defs/l2_character" }
        },
        "l3_objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/l3_row" }
        }
      },
      "additionalProperties": true
    },
    "storyboard_gap_rollup": {
      "type": "object",
      "description": "Aggregation of Lane 10's panels_with_gaps format (build_assembly_layer_hints / bank_gaps.json) across the series' assembly_manifests/*_bank_gaps.json. Reused, not reinvented.",
      "properties": {
        "episodes_with_gap_files": { "type": "array", "items": { "type": "string" } },
        "total_panels_with_gaps": { "type": "integer", "minimum": 0 },
        "gap_asset_counts": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "coverage_summary": {
      "type": "object",
      "required": ["required_render_demand_total", "present_byte_real_total", "coverage_gap_total"],
      "properties": {
        "required_render_demand_total": { "type": "integer", "minimum": 0 },
        "present_byte_real_total": { "type": "integer", "minimum": 0 },
        "coverage_gap_total": { "type": "integer", "minimum": 0 },
        "coverage_pct": { "type": "number" },
        "byte_floor": { "type": "integer" },
        "byte_floor_source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "identity_lock_plan": {
      "type": "object",
      "required": ["pulid_reference_sheets", "flagship_lora"],
      "properties": {
        "engine_note": { "type": "string" },
        "pulid_reference_sheets": {
          "type": "object",
          "required": ["required_for", "present", "gap"],
          "properties": {
            "required_for": { "type": "array", "items": { "type": "string" } },
            "present": { "type": "array", "items": { "type": "string" } },
            "gap": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "flagship_lora": {
          "type": "object",
          "required": ["brand_on_flagship_list", "flagship_list_source"],
          "properties": {
            "brand_on_flagship_list": { "type": "boolean" },
            "flagship_list_source": { "type": "string" },
            "brand_tier": { "type": ["string", "null"] },
            "lora_plan_rows": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
            "authoring_gaps": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "render_queue_estimate": {
      "type": "object",
      "required": ["total_assets_to_render", "method"],
      "properties": {
        "by_class": { "type": "object", "additionalProperties": true },
        "total_assets_to_render": { "type": "integer", "minimum": 0 },
        "gpu_cost_usd_est": { "type": "number" },
        "human_labor_hours_est": { "type": "number" },
        "human_labor_cost_usd_est": { "type": "number" },
        "method": { "type": "string", "minLength": 1 },
        "heuristic_source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "acceptance_layer": {
      "type": "string",
      "enum": [
        "structurally_clear",
        "authored_candidate",
        "system_working",
        "executed_real",
        "proven_at_bar"
      ],
      "description": "This is an analysis artifact: a generator PASS is structurally_clear (the demand math is derived from real inputs); it is never a render claim."
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": true,
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": ["authored", "outline"],
      "description": "authored = backed by an authored bank contract row and/or a detailed (per-episode) master-plan arc; outline = only implied by outline-level arc prose (eps beyond the detailed window) — candidate demand needing bank-contract authoring, not an asserted asset."
    },
    "episodes_touching": {
      "type": "object",
      "required": ["count", "episodes", "method"],
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "episodes": { "type": "array", "items": { "type": "integer" } },
        "method": { "type": "string" }
      },
      "additionalProperties": true
    },
    "l0_row": {
      "type": "object",
      "required": ["scene_id", "source", "render_demand", "present_byte_real", "coverage_gap", "confidence"],
      "properties": {
        "scene_id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["bank_contract", "master_plan_outline"] },
        "layer_class": { "type": "string" },
        "variants": { "type": "array", "items": { "type": "string" } },
        "render_demand": { "type": "integer", "minimum": 0 },
        "episodes_touching": { "$ref": "#/$defs/episodes_touching" },
        "present_byte_real": { "type": "integer", "minimum": 0 },
        "coverage_gap": { "type": "integer", "minimum": 0 },
        "authoring_gap": { "type": "boolean" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    },
    "l2_character": {
      "type": "object",
      "required": ["character_id", "in_bank_contract", "confidence", "identity_lock"],
      "properties": {
        "character_id": { "type": "string", "minLength": 1 },
        "display_name": { "type": "string" },
        "in_bank_contract": { "type": "boolean" },
        "poses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pose_id", "render_demand", "present_byte_real"],
            "properties": {
              "pose_id": { "type": "string", "minLength": 1 },
              "render_demand": { "type": "integer", "minimum": 0 },
              "present_byte_real": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        },
        "pose_render_demand": { "type": "integer", "minimum": 0 },
        "present_byte_real": { "type": "integer", "minimum": 0 },
        "coverage_gap": { "type": "integer", "minimum": 0 },
        "authoring_gap": { "type": "boolean" },
        "episodes_touching": { "$ref": "#/$defs/episodes_touching" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "identity_lock": {
          "type": "object",
          "required": ["pulid_reference_sheet", "reference_sheet_present"],
          "properties": {
            "pulid_reference_sheet": { "type": "string" },
            "reference_sheet_present": { "type": "boolean" },
            "flagship_lora": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "l3_row": {
      "type": "object",
      "required": ["object_id", "source", "render_demand", "recurrence", "present_byte_real", "coverage_gap", "confidence"],
      "properties": {
        "object_id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["bank_contract", "master_plan_outline"] },
        "layer_class": { "type": "string" },
        "state_variants": { "type": "array", "items": { "type": "string" } },
        "render_demand": { "type": "integer", "minimum": 0 },
        "recurrence": { "type": "string", "enum": ["recurring", "one_shot", "unknown"] },
        "episodes_touching": { "$ref": "#/$defs/episodes_touching" },
        "present_byte_real": { "type": "integer", "minimum": 0 },
        "coverage_gap": { "type": "integer", "minimum": 0 },
        "authoring_gap": { "type": "boolean" },
        "confidence": { "$ref": "#/$defs/confidence" }
      },
      "additionalProperties": true
    }
  }
}
