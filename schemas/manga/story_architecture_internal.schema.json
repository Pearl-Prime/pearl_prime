{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/story_architecture_internal.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "series_id", "arc_id", "chapters"],
      "properties": {
        "artifact_type": { "const": "story_architecture_internal" },
        "series_id": { "type": "string", "minLength": 1 },
        "arc_id": { "type": "string", "minLength": 1 },
        "chapters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["chapter_number", "plot_beats"],
            "properties": {
              "chapter_number": { "type": "integer" },
              "chapter_title": { "type": "string" },
              "mini_arc_stage": { "type": "string" },
              "plot_beats": { "type": "array", "items": { "type": "object" } },
              "chapter_end_hook": {},
              "turning_point": {},
              "silence_beats_allocated": { "type": "integer" },
              "villain_presence": { "type": "string" }
            }
          }
        },
        "transmission_audit": { "type": "object" },
        "constraint_checks": { "type": "object" }
      }
    }
  ]
}
