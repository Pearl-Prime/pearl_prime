{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/panel_images_manifest.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "panels"],
      "properties": {
        "artifact_type": { "const": "panel_images_manifest" },
        "panels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["panel_id", "status"],
            "properties": {
              "panel_id": { "type": "string", "minLength": 1 },
              "path": { "type": "string" },
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 },
              "content_sha256": { "$ref": "manga_common.schema.json#/$defs/sha256_hex" },
              "status": { "type": "string", "enum": ["pending", "ok", "failed", "dry_run"] }
            }
          }
        }
      }
    }
  ]
}
