{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/manga/motif_evolution_map.schema.json",
  "allOf": [
    { "$ref": "manga_common.schema.json#/$defs/artifact_base" },
    {
      "type": "object",
      "required": ["artifact_type", "motifs"],
      "properties": {
        "artifact_type": { "const": "motif_evolution_map" },
        "motifs": { "type": "array", "items": { "type": "object" } }
      }
    }
  ]
}
