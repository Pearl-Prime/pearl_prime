{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ite_qc_report.schema.json",
  "title": "ITE QC Report",
  "description": "Output of run_ite_qc — gates T-01 through T-20 plus composite ITE score.",
  "type": "object",
  "required": ["schema_version", "artifact_type", "ITE_score", "gates", "passed"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "artifact_type": {
      "type": "string",
      "const": "ite_qc_report"
    },
    "ITE_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "dimensions": {
      "type": "object",
      "properties": {
        "vt_parasympathetic": { "type": "number", "minimum": 0, "maximum": 1 },
        "vt_processing": { "type": "number", "minimum": 0, "maximum": 1 },
        "vt_somatic": { "type": "number", "minimum": 0, "maximum": 1 },
        "vt_stealth": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "level", "passed", "detail"],
        "properties": {
          "id": { "type": "string", "pattern": "^T-" },
          "level": { "type": "string", "enum": ["BLOCKER", "WARN", "INFO"] },
          "passed": { "type": "boolean" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "blocker_fail_count": { "type": "integer", "minimum": 0 },
    "warn_fail_count": { "type": "integer", "minimum": 0 },
    "passed": { "type": "boolean" },
    "fractal_blocker": { "type": "boolean" }
  },
  "additionalProperties": false
}
