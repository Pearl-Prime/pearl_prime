{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenix-omega.dev/schemas/artifacts/manifest.schema.json",
  "title": "Phoenix Omega R2 Artifact Manifest",
  "description": "Manifest for a set of binary artifacts stored in Cloudflare R2. The repo holds only this manifest; the binary blobs live in R2. See config/artifacts/r2_buckets.yaml and docs/CLOUD_NATIVE_AGENTS_LAYER2.md.",
  "type": "object",
  "required": [
    "manifest_schema",
    "manifest_id",
    "namespace",
    "bucket",
    "artifacts"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_schema": {
      "type": "string",
      "const": "1.0.0"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable id (e.g. 'manga/rendered_books/stillness_press__anxiety/ep_001')"
    },
    "namespace": {
      "type": "string",
      "enum": [
        "manga_rendered_books",
        "manga_portraits",
        "pearl_prime_qa_runs",
        "brand_assets",
        "tmp"
      ],
      "description": "Namespace from config/artifacts/r2_buckets.yaml"
    },
    "bucket": {
      "type": "string",
      "minLength": 1,
      "description": "R2 bucket name, e.g. 'phoenix-omega-artifacts'"
    },
    "produced_by": {
      "type": "string",
      "enum": ["pearl-star", "codespaces", "github-actions", "cloudflare", "operator"],
      "description": "Which environment produced this set of artifacts"
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    },
    "series_id": {
      "type": "string",
      "description": "Optional — for manga manifests, the parent series_id"
    },
    "book_id": {
      "type": "string",
      "description": "Optional — for manga manifests, the parent book_id"
    },
    "run_id": {
      "type": "string",
      "description": "Optional — for QA runs, the run id"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "sha256", "bytes"],
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1,
            "description": "Full R2 key, e.g. 'manga/rendered_books/.../page_01.png'"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "Lowercase hex sha256 of the artifact bytes"
          },
          "bytes": {
            "type": "integer",
            "minimum": 0,
            "description": "Size in bytes"
          },
          "content_type": {
            "type": "string",
            "description": "MIME type (e.g. 'image/png', 'application/epub+zip')"
          },
          "asset_role": {
            "type": "string",
            "description": "Optional semantic role (e.g. 'cover', 'page_01', 'main_portrait')"
          }
        }
      }
    },
    "total_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Sum of all artifact bytes (denormalized for quick checks)"
    },
    "total_artifacts": {
      "type": "integer",
      "minimum": 0,
      "description": "Count (denormalized)"
    },
    "notes": {
      "type": "string"
    }
  }
}
