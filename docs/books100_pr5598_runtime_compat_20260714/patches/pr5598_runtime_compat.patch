+def _write_legacy_duplicate_bank(tmp_path: Path) -> Path:
+    path = tmp_path / "atoms/p/t/INTEGRATION/CANONICAL.txt"
+    path.parent.mkdir(parents=True)
+    path.write_text(
+        """## INTEGRATION v18
+---
+mode: BODY_LANDED
+---
+First legacy body.
+---
+## INTEGRATION v18
+---
+mode: QUESTION_OPEN
+---
+Second legacy body retained by the historical runtime policy.
+---
+""",
+        encoding="utf-8",
+    )
+    return path
+
+
+def test_runtime_pool_reader_tolerates_legacy_duplicate_ids(tmp_path: Path):
+    path = _write_legacy_duplicate_bank(tmp_path)
+
+    entries = _parse_block_file_canonical(
+        path,
+        persona="p",
+        topic="t",
+        slot_type="INTEGRATION",
+    )
+
+    assert [entry.atom_id for entry in entries] == [
+        "p_t_INTEGRATION_v18",
+        "p_t_INTEGRATION_v18",
+    ]
+
+
+def test_runtime_prose_reader_tolerates_legacy_duplicate_ids(tmp_path: Path):
+    path = _write_legacy_duplicate_bank(tmp_path)
+
+    prose = _parse_block_file_with_prose(
+        path,
+        persona="p",
+        topic="t",
+        slot_type="INTEGRATION",
+        required=True,
+    )
+
+    assert prose == {
+        "p_t_INTEGRATION_v18":
+            "Second legacy body retained by the historical runtime policy."
+    }
